<script>
const CARDS = ['c0','c1','c2','c3','c4','c5','c6','c7'];
const N = CARDS.length;
let cur = 0;
let autoTimer = null;

function buildProgress() {
  const bar = document.getElementById('progress');
  CARDS.forEach((_, i) => {
    const seg = document.createElement('div');
    seg.className = 'prog-seg' + (i === 0 ? ' active' : '');
    seg.id = 'ps' + i;
    bar.appendChild(seg);
  });
}

function updateProgress(idx) {
  CARDS.forEach((_, i) => {
    const seg = document.getElementById('ps' + i);
    seg.className = 'prog-seg' + (i < idx ? ' done' : i === idx ? ' active' : '');
  });
}

function goTo(idx) {
  if (idx < 0 || idx >= N) return;
  const prev = document.getElementById(CARDS[cur]);
  prev.classList.remove('active');
  prev.classList.add('exit');
  setTimeout(() => prev.classList.remove('exit'), 400);
  cur = idx;
  const next = document.getElementById(CARDS[cur]);
  next.classList.add('active');
  updateProgress(cur);
  updateCounter();
  updateArrows();
  startAuto();
}

function next() { if (cur < N - 1) goTo(cur + 1); }
function prev() { if (cur > 0) goTo(cur - 1); }

function updateCounter() {
  document.getElementById('counter').textContent = `${cur + 1} / ${N}`;
}

function updateArrows() {
  document.getElementById('arrow-prev').style.opacity = cur === 0 ? '0' : '0.25';
  document.getElementById('arrow-next').style.opacity = cur === N - 1 ? '0' : '0.25';
}

function startAuto() {
  if (autoTimer) clearTimeout(autoTimer);
  if (cur < N - 1) {
    autoTimer = setTimeout(() => next(), 5000);
  }
}

// Keyboard
document.addEventListener('keydown', e => {
  if (e.key === 'ArrowRight' || e.key === ' ') { e.preventDefault(); next(); }
  if (e.key === 'ArrowLeft') { e.preventDefault(); prev(); }
});

// Touch swipe
let tx = 0, ty = 0;
document.getElementById('stage').addEventListener('touchstart', e => {
  tx = e.touches[0].clientX;
  ty = e.touches[0].clientY;
}, { passive: true });
document.getElementById('stage').addEventListener('touchend', e => {
  const dx = e.changedTouches[0].clientX - tx;
  const dy = e.changedTouches[0].clientY - ty;
  if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 40) {
    dx < 0 ? next() : prev();
  }
}, { passive: true });

buildProgress();
updateCounter();
updateArrows();
startAuto();
</script>
