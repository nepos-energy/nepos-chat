<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Battery Swap Argentina</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Instrument+Serif:ital@0;1&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --teal:    #00C49A;
  --teal-d:  #00896B;
  --gold:    #F0B429;
  --ink:     #0A0E14;
  --ink2:    #131923;
  --paper:   #F2EDE4;
  --muted:   rgba(242,237,228,0.5);
  --border:  rgba(242,237,228,0.12);
  --bebas:   'Bebas Neue', sans-serif;
  --serif:   'Instrument Serif', Georgia, serif;
  --sans:    'DM Sans', sans-serif;
  --mono:    'DM Mono', monospace;
}

html, body {
  width: 100%;
  height: 100%;
  background: var(--ink);
  overflow: hidden;
  font-family: var(--sans);
  color: var(--paper);
  -webkit-font-smoothing: antialiased;
}

/* ── CONTAINER: fixed 9:16 centered ── */
#app {
  position: fixed;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #06090D;
}

#stage {
  position: relative;
  width: min(100vw, calc(100vh * 9/16));
  height: min(100vh, calc(100vw * 16/9));
  max-width: 420px;
  max-height: calc(420px * 16/9);
  overflow: hidden;
  background: var(--ink);
}

/* ── CARDS ── */
.card {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  padding: 44px 32px 36px;
  opacity: 0;
  transform: translateY(32px) scale(0.98);
  transition: opacity 0.5s cubic-bezier(.4,0,.2,1),
              transform 0.5s cubic-bezier(.4,0,.2,1);
  pointer-events: none;
  overflow: hidden;
}
.card.active {
  opacity: 1;
  transform: translateY(0) scale(1);
  pointer-events: all;
}
.card.exit {
  opacity: 0;
  transform: translateY(-24px) scale(1.01);
  transition: opacity 0.35s ease, transform 0.35s ease;
}

/* ── PROGRESS BAR ── */
#progress {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  z-index: 50;
  display: flex;
  gap: 3px;
  padding: 0 6px;
}
.prog-seg {
  flex: 1;
  height: 3px;
  border-radius: 2px;
  background: rgba(255,255,255,0.15);
  overflow: hidden;
  margin-top: 6px;
}
.prog-seg.done { background: var(--teal); }
.prog-seg.active {
  background: rgba(255,255,255,0.15);
  position: relative;
}
.prog-seg.active::after {
  content: '';
  position: absolute;
  inset: 0;
  background: var(--teal);
  transform-origin: left;
  animation: fillBar 4s linear forwards;
}
@keyframes fillBar { from { transform: scaleX(0); } to { transform: scaleX(1); } }

/* ── NAV TAP ZONES ── */
#tap-prev, #tap-next {
  position: absolute;
  top: 0; bottom: 0;
  width: 40%;
  z-index: 40;
  cursor: pointer;
  -webkit-tap-highlight-color: transparent;
}
#tap-prev { left: 0; }
#tap-next { right: 0; }

/* ── ARROW HINTS ── */
#arrow-prev, #arrow-next {
  position: absolute;
  bottom: 18px;
  z-index: 45;
  font-size: 18px;
  opacity: 0.25;
  pointer-events: none;
  transition: opacity 0.3s;
}
#arrow-prev { left: 20px; }
#arrow-next { right: 20px; }

/* ── COUNTER ── */
#counter {
  position: absolute;
  bottom: 18px;
  left: 50%;
  transform: translateX(-50%);
  font-family: var(--mono);
  font-size: 10px;
  color: rgba(255,255,255,0.2);
  z-index: 45;
  pointer-events: none;
  letter-spacing: 0.08em;
}

/* ── TYPOGRAPHY ── */
.eyebrow {
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--teal);
  margin-bottom: 12px;
}
.eyebrow.gold { color: var(--gold); }
.eyebrow.muted { color: var(--muted); }

.big-num {
  font-family: var(--bebas);
  font-size: clamp(72px, 20vw, 96px);
  line-height: 0.9;
  letter-spacing: 0.02em;
  color: var(--teal);
}
.big-num.gold { color: var(--gold); }
.big-num.paper { color: var(--paper); }

.headline {
  font-family: var(--serif);
  font-size: clamp(28px, 8vw, 38px);
  line-height: 1.1;
  font-weight: 400;
}
.headline em { font-style: italic; color: var(--teal); }
.headline.gold em { color: var(--gold); }

.subhead {
  font-family: var(--sans);
  font-size: clamp(13px, 3.5vw, 15px);
  font-weight: 300;
  line-height: 1.6;
  color: var(--muted);
}

.label {
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.08em;
  color: var(--muted);
  text-transform: uppercase;
}

/* ── DIVIDER ── */
.hr {
  height: 1px;
  background: var(--border);
  margin: 16px 0;
}

/* ── STAT ROW ── */
.stat-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding: 12px 0;
  border-bottom: 1px solid var(--border);
}
.stat-row:first-child { border-top: 1px solid var(--border); }
.stat-name { font-size: 13px; font-weight: 300; color: var(--muted); }
.stat-val {
  font-family: var(--bebas);
  font-size: 28px;
  letter-spacing: 0.04em;
  color: var(--paper);
  line-height: 1;
}
.stat-val.teal { color: var(--teal); }
.stat-val.gold { color: var(--gold); }

/* ── PILL ── */
.pill {
  display: inline-block;
  font-family: var(--mono);
  font-size: 9px;
  padding: 3px 8px;
  border-radius: 100px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}
.pill.teal { background: rgba(0,196,154,0.15); color: var(--teal); }
.pill.gold { background: rgba(240,180,41,0.15); color: var(--gold); }
.pill.muted { background: rgba(255,255,255,0.07); color: var(--muted); }

/* ── ROLE BLOCK ── */
.role-block {
  border-left: 3px solid;
  padding: 10px 14px;
  margin-bottom: 10px;
  border-radius: 0 6px 6px 0;
}
.role-block.co  { border-color: #4A90E2; background: rgba(74,144,226,0.08); }
.role-block.me  { border-color: var(--teal); background: rgba(0,196,154,0.08); }
.role-block.neo { border-color: var(--gold); background: rgba(240,180,41,0.08); }
.role-flag { font-family: var(--mono); font-size: 9px; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 3px; }
.role-flag.co  { color: #4A90E2; }
.role-flag.me  { color: var(--teal); }
.role-flag.neo { color: var(--gold); }
.role-body { font-size: 12px; font-weight: 300; color: var(--muted); line-height: 1.6; }
.role-body span { color: var(--paper); font-weight: 400; }

/* ── EQUITY BAR ── */
.eq-wrap { margin: 16px 0 8px; }
.eq-label { font-family: var(--mono); font-size: 9px; color: var(--muted); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 6px; }
.eq-bar { display: flex; height: 28px; border-radius: 4px; overflow: hidden; gap: 2px; }
.eq-seg { display: flex; align-items: center; justify-content: center; font-family: var(--mono); font-size: 9px; font-weight: 500; border-radius: 2px; }
.eq-seg.co  { background: #4A90E2; color: white; }
.eq-seg.me  { background: var(--teal-d); color: white; }
.eq-seg.neo { background: rgba(240,180,41,0.7); color: var(--ink); }
.eq-seg.pool{ background: rgba(255,255,255,0.15); color: var(--muted); }

/* ── HIGHLIGHT BOX ── */
.hi-box {
  border: 1px solid rgba(0,196,154,0.3);
  border-left: 3px solid var(--teal);
  background: rgba(0,196,154,0.07);
  border-radius: 0 8px 8px 0;
  padding: 14px 16px;
  margin: 14px 0;
}
.hi-box.gold {
  border-color: rgba(240,180,41,0.3);
  border-left-color: var(--gold);
  background: rgba(240,180,41,0.07);
}
.hi-box-val {
  font-family: var(--bebas);
  font-size: 36px;
  color: var(--teal);
  line-height: 1;
}
.hi-box-val.gold { color: var(--gold); }
.hi-box-label { font-size: 12px; font-weight: 300; color: var(--muted); margin-top: 2px; }

/* ── STEP ROW ── */
.step-row { display: flex; gap: 12px; align-items: flex-start; margin-bottom: 14px; }
.step-num {
  font-family: var(--bebas);
  font-size: 32px;
  color: var(--teal);
  line-height: 1;
  min-width: 28px;
}
.step-body { flex: 1; }
.step-title { font-size: 13px; font-weight: 500; color: var(--paper); margin-bottom: 2px; }
.step-sub { font-size: 11px; font-weight: 300; color: var(--muted); line-height: 1.5; }

/* ── BG EFFECTS ── */
.bg-glow {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
}

/* ── CARD BACKGROUNDS ── */
/* C0 — cover: dark with city silhouette */
#c0 { background: var(--ink); }
/* C1 — hook: dark */
#c1 { background: var(--ink2); }
/* C2 — pain point */
#c2 { background: #0D1520; }
/* C3 — window */
#c3 { background: var(--ink); }
/* C4 — model */
#c4 { background: #0A1410; }
/* C5 — numbers */
#c5 { background: var(--ink2); }
/* C6 — steps */
#c6 { background: #0A0E14; }
/* C7 — close */
#c7 { background: var(--teal-d); }

/* All content above bg */
.card > *:not(.bg-glow):not(.city-bg) { position: relative; z-index: 2; }
.bg-glow { position: absolute !important; z-index: 0 !important; }

/* ── ANIMATIONS ── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(14px); }
  to   { opacity: 1; transform: translateY(0); }
}
.card.active .an { opacity: 0; animation: fadeUp 0.45s ease forwards; }
.card.active .a1 { animation-delay: 0.08s; }
.card.active .a2 { animation-delay: 0.18s; }
.card.active .a3 { animation-delay: 0.28s; }
.card.active .a4 { animation-delay: 0.38s; }
.card.active .a5 { animation-delay: 0.48s; }
.card.active .a6 { animation-delay: 0.58s; }

/* ── CITY SVG BG ── */
.city-bg {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 45%;
  z-index: 1;
  pointer-events: none;
}
</style>
</head>
<body>
<div id="app">
<div id="stage">

