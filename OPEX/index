function buildP5(){
  var p=PROY[curP],tp=tpvReal(),tn=gvS('tn',p.def.tn||0.10),cm=consumoMesTotal();
  var Tv=T[p.tipo];
  var dem=calcDemanda(p, false);       // Factura actual SIN SGDA
  var demSGDA=calcDemanda(p, true);    // Factura CON SGDA (60% obligatorio)
  var genM1=genSolarAnio(p.kwp,gv('dg')/100,0)/12;

  // Factura actual (sin solar)
  var fE=cargoEnergiaMes(), fD=dem.cargoDem, fS=p.sapg||0, fC=p.comerc||4.182, fB=p.bomberos||0;
  var totalActual=p.facturaMes;

  // Con SGDA (solar + balance neto ARCONEL-005/24)
  // Demanda con SGDA: 60% de la máxima 12 meses (ARCONEL-001/20)
  var sgd=calcSGDA();
  var factMes=sgd.total.fact/12;
  // Energía facturable por franja (SGDA compensa según franja correspondiente)
  var fESGDA=factMes * tp;   // energía facturable × tarifa ponderada del proyecto
  var fDsgda = demSGDA.cargoDem;  // demanda = 60% DMmax12 con SGDA activo
  // SAPG: cargo fijo NO reducible con solar (base en potencia contratada, no en consumo)
  var totalSGDA=fESGDA+fDsgda+fS+fC+fB;
  var ahSGDA=totalActual-totalSGDA;

  // Con Nepos EaaS
  // Piso regulatorio = 60% demanda máx. + SAPG + comercialización + bomberos
  var cuotaSinIVA=genM1*tn;
  var cuotaConIVA=cuotaSinIVA*1.15;
  var pisoReg=demSGDA.cargoDemSGDA+fS+fC+fB;  // usa el 60% correcto
  var totalNepos=cuotaConIVA+pisoReg;
  var ahNepos=totalActual-totalNepos;
  var ahPct=totalActual>0?ahNepos/totalActual*100:0;
  
  // Costo diario de inacción (lo que pierde el cliente cada día sin tomar la decisión)
  var costoDiarioInaccion = ahNepos / 30.0;

  $("p5-badge").innerHTML="<strong>"+p.cliente+"</strong> paga <strong>"+fUSD2(totalNepos)+"</strong>/mes con Nepos vs "+
