  };
  r.distribuidor = null;
  for(var k in distMap){ if(t.indexOf(k) !== -1){ r.distribuidor = distMap[k]; break; } }

  return r;
}

function npParseInformeFV(text){
  var t = text.toUpperCase();
  var r = {};

  r.gen_anual_kwh = npFindNum(t, [
    /PRODUCCI[OÓ]N\s+ANUAL[^\d]*([\d.,]+)\s*KWH/,
    /GENERACI[OÓ]N\s+ANUAL[^\d]*([\d.,]+)/,
    /ENERG[IÍ]A\s+ANUAL[^\d]*([\d.,]+)/,
    /ANNUAL\s+ENERGY[^\d]*([\d.,]+)/,
    /E_GRID[^\d]*([\d.,]+)/,
    /YIELD[^\d]*([\d.,]+)\s*KWH/
  ]);

  // Si viene en MWh, convertir
  var genMWh = npFindNum(t, [
    /PRODUCCI[OÓ]N\s+ANUAL[^\d]*([\d.,]+)\s*MWH/,
    /GENERACI[OÓ]N\s+ANUAL[^\d]*([\d.,]+)\s*MWH/,
    /ANNUAL\s+ENERGY[^\d]*([\d.,]+)\s*MWH/
  ]);
  if(genMWh && (!r.gen_anual_kwh || genMWh*1000 > r.gen_anual_kwh)){
    r.gen_anual_kwh = genMWh * 1000;
  }

  r.kwp = npFindNum(t, [
    /POTENCIA\s+INSTALADA[^\d]*([\d.,]+)\s*KWP/,
    /POTENCIA\s+PICO[^\d]*([\d.,]+)/,
    /PEAK\s+POWER[^\d]*([\d.,]+)/,
    /PNOM[^\d]*([\d.,]+)\s*KWP/,
    /SYSTEM\s+SIZE[^\d]*([\d.,]+)/
  ]);

  r.pr_pct = npFindNum(t, [
    /PERFORMANCE\s+RATIO[^\d]*([\d.,]+)/,
    /PR[^\d]*([\d.,]+)\s*%/,
    /RENDIMIENTO[^\d]*([\d.,]+)\s*%/
  ]);

  r.irr_kwh_kwp_dia = npFindNum(t, [
    /IRRADIACI[OÓ]N[^\d]*([\d.,]+)\s*KWH/,
    /IRRADIANCE[^\d]*([\d.,]+)/,
    /GHI[^\d]*([\d.,]+)/,
    /RADIACI[OÓ]N\s+GLOBAL[^\d]*([\d.,]+)/
  ]);

  return r;
}

function npParseCotizacion(text){
  var t = text.toUpperCase();
  var r = {};

  r.capex_usd = npFindNum(t, [
    /TOTAL\s+PROYECTO[^\d]*([\d.,]+)/,
    /PRECIO\s+TOTAL[^\d]*([\d.,]+)/,
    /VALOR\s+TOTAL[^\d]*([\d.,]+)/,
    /COSTO\s+TOTAL[^\d]*([\d.,]+)/,
    /INVERSI[OÓ]N\s+TOTAL[^\d]*([\d.,]+)/,
    /TOTAL\s+USD[^\d]*([\d.,]+)/,
    /TOTAL\s+OFERTA[^\d]*([\d.,]+)/
  ]);

  r.kwp = npFindNum(t, [
    /POTENCIA[^\d]*([\d.,]+)\s*KWP/,
    /SISTEMA[^\d]*([\d.,]+)\s*KWP/,
    /CAPACIDAD[^\d]*([\d.,]+)\s*KWP/
  ]);

  r.om_anual_usd = npFindNum(t, [
    /O&M[^\d]*([\d.,]+)/,
    /MANTENIMIENTO\s+ANUAL[^\d]*([\d.,]+)/,
    /OPERACI[OÓ]N\s+Y\s+MANTENIMIENTO[^\d]*([\d.,]+)/
  ]);

  return r;
}

// ── PLANILLAS DE LUZ ────────────────────────────────────────────
function npHandleFiles(){
  var fi    = $("np-planillas");
  var info  = $("np-planillas-info");
  var prev  = $("np-planillas-preview");
  if(!fi || !fi.files || !fi.files.length) return;
  var names = [];
  for(var i=0;i<fi.files.length;i++) names.push(fi.files[i].name);
  var tipo = $("np-tipo-val").value;

  if(info) info.innerHTML = "📄 "+names.join(", ")+"<br><span style='color:var(--az);font-weight:600'>⏳ Leyendo planilla...</span>";
  if(prev) prev.innerHTML = "<div style='background:var(--az-lt);border:1px solid var(--az-bd);border-radius:8px;padding:9px 11px;font-size:11px;color:var(--az)'>⏳ Extrayendo datos...</div>";

  var docType = tipo==='BV' ? 'planillaBV' : 'planillaMV';
  npExtractPdfText(fi.files[0],
    function(result){
      // Caso Vision: ya viene parseado como objeto JSON
      if(result && typeof result === 'object' && result.__visionParsed){
        delete result.__visionParsed;
        npApplyExtracted(result, tipo, names, info, prev);
        return;
      }
      var text = result;
      if(typeof text !== 'string'){ text = ""; }
      if(text.indexOf('__IMAGE__') === 0){
        if(info) info.innerHTML="📄 "+names.join(", ")+"<br><span style='color:var(--am)'>⚠️ Las imágenes no se pueden procesar automáticamente. Use archivos PDF o ingrese los datos manualmente.</span>";
        if(prev) prev.innerHTML=""; return;
      }
      if(text.indexOf('__SCAN__') === 0){
        if(info) info.innerHTML="📄 "+names.join(", ")+"<br><span style='color:var(--am)'>⚠️ PDF escaneado sin texto. Ingrese los datos manualmente.</span>";
        if(prev) prev.innerHTML=""; return;
      }
      var ex = tipo==='BV' ? npParsePlanillaBV(text) : npParsePlanillaMV(text);
      npApplyExtracted(ex, tipo, names, info, prev);
    },
    function(err){
      if(info) info.innerHTML="📄 "+names.join(", ")+"<br><span style='color:var(--rj)'>❌ Error al leer el PDF: "+err+"</span><br><span style='color:var(--t4);font-size:10px'>Ingrese los datos manualmente.</span>";
      if(prev) prev.innerHTML="";
    },
    docType
  );
}

function npApplyExtracted(ex, tipo, names, info, prev){
  var applied = [];
  if(tipo==='BV'){
    if(ex.consumo_total_kwh > 0){
      var cb=$("np-cons-bv"); if(cb){ cb.value=Math.round(ex.consumo_total_kwh); applied.push("Consumo: "+Math.round(ex.consumo_total_kwh)+" kWh"); }
      if(ex.consumo_dia_kwh > 0 && ex.consumo_total_kwh > 0){
        var pctD = Math.round(ex.consumo_dia_kwh / ex.consumo_total_kwh * 100);
        var pd=$("np-pct-dia"); if(pd){ pd.value=pctD; applied.push("Día: "+pctD+"%"); }
        var pn=$("np-pct-noche"); if(pn){ pn.value=(100-pctD); }
      }
    }
    if(ex.demanda_kw > 0){ var db=$("np-dem-bv"); if(db){ db.value=ex.demanda_kw; applied.push("Demanda: "+ex.demanda_kw+" kW"); } }
    if(ex.factura_total_usd > 0){ var fb=$("np-fac-bv"); if(fb){ fb.value=ex.factura_total_usd; applied.push("Factura: $"+ex.factura_total_usd); } }
  } else {
    if(ex.kwh_media > 0){ var qm=$("np-kwh-media"); if(qm){ qm.value=Math.round(ex.kwh_media); applied.push("Media: "+Math.round(ex.kwh_media)+" kWh"); } }
    if(ex.kwh_punta > 0){ var qp=$("np-kwh-punta"); if(qp){ qp.value=Math.round(ex.kwh_punta); applied.push("Punta: "+Math.round(ex.kwh_punta)+" kWh"); } }
    if(ex.kwh_base  > 0){ var qb=$("np-kwh-base");  if(qb){ qb.value=Math.round(ex.kwh_base);  applied.push("Base: "+Math.round(ex.kwh_base)+" kWh");  } }
    if(ex.kwh_fds   > 0){ var qf=$("np-kwh-fds");   if(qf){ qf.value=Math.round(ex.kwh_fds);   applied.push("FdS: "+Math.round(ex.kwh_fds)+" kWh");   } }
    if(ex.demanda_kw > 0){ var dm=$("np-dem-mv"); if(dm){ dm.value=ex.demanda_kw; applied.push("Demanda: "+ex.demanda_kw+" kW"); } }
    if(ex.demanda_max_12_kw > 0){ var dmx=$("np-demmax-mv"); if(dmx){ dmx.value=ex.demanda_max_12_kw; } }
    if(ex.factura_total_usd > 0){ var fm=$("np-fac-mv"); if(fm){ fm.value=ex.factura_total_usd; applied.push("Factura: $"+ex.factura_total_usd); } }
    if(ex.sapg_usd > 0){ var sp=$("np-sapg"); if(sp){ sp.value=ex.sapg_usd; applied.push("SAPG: $"+ex.sapg_usd); } }
    if(ex.comercializacion_usd > 0){ var co=$("np-comerc"); if(co){ co.value=ex.comercializacion_usd; } }
    if(ex.bomberos_usd > 0){ var bo=$("np-bomb"); if(bo){ bo.value=ex.bomberos_usd; } }
    npUpdateMvTarifa();
  }
  // Match distribuidor
  if(ex.distribuidor){
    var nd=$("np-dist");
    if(nd){
      var dv = ex.distribuidor.toUpperCase();
      var opts = nd.options;
      for(var oi=0;oi<opts.length;oi++){
        if(dv.indexOf(opts[oi].value.split(' ')[0].toUpperCase()) !== -1){ nd.selectedIndex=oi; break; }
      }
    }
  }
  var msg = applied.length > 0
    ? "<span style='color:var(--vd);font-weight:600'>✅ Extraído: "+applied.join(" · ")+"</span>"
    : "<span style='color:var(--am)'>⚠️ IA procesó el archivo pero no encontró datos numéricos claros. Ingrese los datos manualmente.</span>";
  if(info) info.innerHTML = "📄 "+names.join(", ")+"<br>"+msg+"<br><span style='color:var(--t4);font-size:10px'>Puede editar los campos si hay diferencias con la planilla original.</span>";
  if(prev) prev.innerHTML = applied.length > 0
    ? "<div style='background:var(--vd-lt);border:1px solid var(--vd-bd);border-radius:8px;padding:8px 11px;font-size:11px;color:var(--vd)'>✅ Campos completados automáticamente. Verifique y ajuste si es necesario.</div>"
    : "";
}

// ── INFORME DE GENERACIÓN FV ─────────────────────────────────────
function npHandleInforme(){
  var fi   = $("np-informe-gen");
  var info = $("np-informe-info");
  if(!fi || !fi.files || !fi.files.length) return;
  var fname = fi.files[0].name;
  if(info) info.innerHTML = "📄 "+fname+"<br><span style='color:var(--az);font-weight:600'>⏳ Leyendo informe solar...</span>";

  npExtractPdfText(fi.files[0],
    function(result){
      if(result && typeof result === 'object' && result.__visionParsed){
        delete result.__visionParsed;
        var ex = result;
        if(!ex.gen_anual_kwh || ex.gen_anual_kwh <= 0){
          if(info) info.innerHTML="📄 "+fname+"<br><span style='color:var(--am)'>⚠️ No se encontró la generación anual. Ingrese los valores manualmente.</span>";
          return;
        }
        if(ex.kwp > 0 && !(parseFloat($("np-kwp").value)>0)){ var nk=$("np-kwp"); if(nk) nk.value=ex.kwp; }
        if(ex.pr_pct > 0 && ex.pr_pct <= 100){ var npr=$("np-pr"); if(npr) npr.value=ex.pr_pct; }
        if(ex.irr_kwh_kwp_dia > 0 && ex.irr_kwh_kwp_dia < 10){ var nirr=$("np-irr"); if(nirr) nirr.value=ex.irr_kwh_kwp_dia.toFixed(2); }
        npCalcGen();
        var genMes = Math.round(ex.gen_anual_kwh / 12);
        var gm=$("np-gen-mes"); if(gm) gm.value = genMes;
        var ga=$("np-gen-año"); if(ga) ga.value = Math.round(ex.gen_anual_kwh);
        if(info) info.innerHTML = "✅ <strong>Generación extraída (OCR):</strong> "
          +Math.round(ex.gen_anual_kwh).toLocaleString()+" kWh/año · "+genMes.toLocaleString()+" kWh/mes"
          +(ex.pr_pct?" · PR="+ex.pr_pct+"%":"")
          +(ex.irr_kwh_kwp_dia?" · Irr="+ex.irr_kwh_kwp_dia.toFixed(2)+" kWh/kWp/d":"")
          +"<br><span style='color:var(--t4);font-size:10px'>Fuente: "+fname+"</span>";
        return;
      }
      var text = (typeof result === 'string') ? result : "";
      if(text.indexOf('__IMAGE__') === 0){
        if(info) info.innerHTML="📄 "+fname+"<br><span style='color:var(--am)'>⚠️ Use el PDF del informe, no una imagen.</span>";
        return;
      }
      if(text.indexOf('__SCAN__') === 0){
        if(info) info.innerHTML="📄 "+fname+"<br><span style='color:var(--am)'>⚠️ PDF escaneado sin texto legible. Ingrese los valores manualmente.</span>";
        return;
      }
      var ex = npParseInformeFV(text);
      if(!ex.gen_anual_kwh || ex.gen_anual_kwh <= 0){
        if(info) info.innerHTML="📄 "+fname+"<br><span style='color:var(--am)'>⚠️ No se encontró la generación anual en el informe. Ingrese los valores manualmente.</span>";
        return;
      }
      if(ex.kwp > 0 && !(parseFloat($("np-kwp").value)>0)){ var nk=$("np-kwp"); if(nk) nk.value=ex.kwp; }
      if(ex.pr_pct > 0 && ex.pr_pct <= 100){ var npr=$("np-pr"); if(npr) npr.value=ex.pr_pct; }
      if(ex.irr_kwh_kwp_dia > 0 && ex.irr_kwh_kwp_dia < 10){ var nirr=$("np-irr"); if(nirr) nirr.value=ex.irr_kwh_kwp_dia.toFixed(2); }
      npCalcGen();
      var genMes = Math.round(ex.gen_anual_kwh / 12);
      var gm=$("np-gen-mes"); if(gm) gm.value = genMes;
      var ga=$("np-gen-año"); if(ga) ga.value = Math.round(ex.gen_anual_kwh);
      if(info) info.innerHTML = "✅ <strong>Generación extraída:</strong> "
        +Math.round(ex.gen_anual_kwh).toLocaleString()+" kWh/año · "+genMes.toLocaleString()+" kWh/mes"
        +(ex.pr_pct?" · PR="+ex.pr_pct+"%":"")
        +(ex.irr_kwh_kwp_dia?" · Irr="+ex.irr_kwh_kwp_dia.toFixed(2)+" kWh/kWp/d":"")
        +"<br><span style='color:var(--t4);font-size:10px'>Fuente: "+fname+"</span>";
    },
    function(err){
      if(info) info.innerHTML="📄 "+fname+"<br><span style='color:var(--rj)'>❌ "+err+"</span><br><span style='color:var(--t4);font-size:10px'>Ingrese la generación manualmente.</span>";
    },
    'informeFV'
  );
}

// ── COTIZACIÓN CAPEX ─────────────────────────────────────────────
function npHandleCotizacion(){
  var fi   = $("np-cotizacion");
  var info = $("np-cotizacion-info");
  if(!fi || !fi.files || !fi.files.length) return;
  var fname = fi.files[0].name;
  if(info) info.innerHTML = "📄 "+fname+"<br><span style='color:var(--az);font-weight:600'>⏳ Leyendo cotización CAPEX...</span>";

  npExtractPdfText(fi.files[0],
    function(result){
      if(result && typeof result === 'object' && result.__visionParsed){
        delete result.__visionParsed;
        var ex = result;
        if(!ex.capex_usd || ex.capex_usd <= 0){
          if(info) info.innerHTML="📄 "+fname+"<br><span style='color:var(--am)'>⚠️ No se encontró el CAPEX total. Ingréselo manualmente.</span>";
          return;
        }
        var nc=$("np-capex"); if(nc) nc.value=ex.capex_usd;
        if(ex.om_anual_usd > 0){ var no=$("np-om"); if(no) no.value=ex.om_anual_usd; }
        if(ex.kwp > 0 && !(parseFloat($("np-kwp").value)>0)){ var nk=$("np-kwp"); if(nk) nk.value=ex.kwp; }
        npCalcCapexkwp(); npCalcGen();
        if(info) info.innerHTML = "✅ <strong>CAPEX extraído (OCR):</strong> $"+Math.round(ex.capex_usd).toLocaleString()
          +(ex.kwp?" · "+ex.kwp+" kWp":"")
          +(ex.om_anual_usd?" · O&M: $"+Math.round(ex.om_anual_usd)+"/año":"")
          +"<br><span style='color:var(--t4);font-size:10px'>Verifique antes de continuar. Fuente: "+fname+"</span>";
        return;
      }
      var text = (typeof result === 'string') ? result : "";
      if(text.indexOf('__IMAGE__') === 0){
        if(info) info.innerHTML="📄 "+fname+"<br><span style='color:var(--am)'>⚠️ Use el PDF de la cotización, no una imagen.</span>";
        return;
      }
      if(text.indexOf('__SCAN__') === 0){
        if(info) info.innerHTML="📄 "+fname+"<br><span style='color:var(--am)'>⚠️ PDF escaneado sin texto legible. Ingrese el CAPEX manualmente.</span>";
        return;
      }
      var ex = npParseCotizacion(text);
      if(!ex.capex_usd || ex.capex_usd <= 0){
        if(info) info.innerHTML="📄 "+fname+"<br><span style='color:var(--am)'>⚠️ No se encontró el CAPEX total en la cotización. Ingréselo manualmente.</span>";
        return;
      }
      var nc=$("np-capex"); if(nc) nc.value=ex.capex_usd;
      if(ex.om_anual_usd > 0){ var no=$("np-om"); if(no) no.value=ex.om_anual_usd; }
      if(ex.kwp > 0 && !(parseFloat($("np-kwp").value)>0)){ var nk=$("np-kwp"); if(nk) nk.value=ex.kwp; }
      npCalcCapexkwp(); npCalcGen();
      if(info) info.innerHTML = "✅ <strong>CAPEX extraído:</strong> $"+Math.round(ex.capex_usd).toLocaleString()
        +(ex.kwp?" · "+ex.kwp+" kWp":"")
        +(ex.om_anual_usd?" · O&M: $"+Math.round(ex.om_anual_usd)+"/año":"")
        +"<br><span style='color:var(--t4);font-size:10px'>Verifique antes de continuar. Fuente: "+fname+"</span>";
    },
    function(err){
      if(info) info.innerHTML="📄 "+fname+"<br><span style='color:var(--rj)'>❌ "+err+"</span><br><span style='color:var(--t4);font-size:10px'>Ingrese el CAPEX manualmente.</span>";
    },
    'cotizacion'
  );
}

function npCrear(){
  var errs = npValidate();
  var errEl = $("np-errores");
  if(errs.length > 0){
    errEl.innerHTML="⚠️ <strong>Complete los siguientes campos:</strong><br>"+errs.join("<br>");
    errEl.style.display="block";
    return;
  }
  errEl.style.display="none";

  var d = npGetData();
  d._custom = true;

  // ── MODO EDICIÓN: actualizar proyecto existente ──
  if(EDITING_PROJ_IDX !== null){
    var ei = EDITING_PROJ_IDX;
    d._custom = true;
    PROY[ei] = d;
    EDITING_PROJ_IDX = null;
    // Actualizar label del chip
    var wrap = $("chip-wrap-"+ei);
    if(wrap){
      var lbl = wrap.querySelector(".chip-label");
      if(lbl) lbl.textContent = d.nombre.length>18 ? d.nombre.substring(0,16)+"…" : d.nombre;
    }
    closeNewProj();
    loadProj(ei);
    return;
  }

  // ── MODO CREACIÓN: buscar slot libre ──
  var targetIdx = 6;
  for(var si=6; si<=20; si++){
    if(!PROY[si] || !PROY[si]._custom){ targetIdx=si; break; }
  }
  PROY[targetIdx] = d;

  var newLabel = d.nombre.length>18 ? d.nombre.substring(0,16)+"…" : d.nombre;

  // Crear wrapper con chip + botones de acción
  function makeChipWrap(idx, label){
    var plusBtn = $("chip-new-btn");
    if(!plusBtn) return;
    var wrap = document.createElement("span");
    wrap.id = "chip-wrap-"+idx;
    wrap.style.cssText = "display:inline-flex;align-items:center;gap:2px;margin:0 2px";

    var chipBtn = document.createElement("button");
    chipBtn.className = "chip";
    chipBtn.id = "chip-"+idx;
    chipBtn.style.borderStyle = "solid";
    chipBtn.style.margin = "0";
    chipBtn.innerHTML = "<span class='chip-label'>"+label+"</span>";
    chipBtn.onclick = (function(i){ return function(){ loadProj(i); }; })(idx);

    var editBtn = document.createElement("button");
    editBtn.title = "Editar proyecto";
    editBtn.style.cssText = "padding:3px 5px;font-size:10px;border:1px solid var(--az-bd);border-radius:5px;background:var(--az-lt);color:var(--az);cursor:pointer;line-height:1";
    editBtn.textContent = "✏️";
    editBtn.onclick = (function(i){ return function(e){ e.stopPropagation(); npEditProj(i); }; })(idx);

    var delBtn = document.createElement("button");
    delBtn.title = "Borrar proyecto";
    delBtn.style.cssText = "padding:3px 5px;font-size:10px;border:1px solid var(--rj-bd);border-radius:5px;background:var(--rj-lt);color:var(--rj);cursor:pointer;line-height:1";
    delBtn.textContent = "🗑";
    delBtn.onclick = (function(i){ return function(e){ e.stopPropagation(); npDeleteProj(i); }; })(idx);

    wrap.appendChild(chipBtn);
    wrap.appendChild(editBtn);
    wrap.appendChild(delBtn);
    plusBtn.parentNode.insertBefore(wrap, plusBtn);
  }

  makeChipWrap(targetIdx, newLabel);
  closeNewProj();
  loadProj(targetIdx);
}

// Event listeners para file inputs (no-jQuery compatible)
document.addEventListener('DOMContentLoaded', function(){
  var pf=$("np-planillas");    if(pf) pf.addEventListener('change', npHandleFiles);
  var ig=$("np-informe-gen");  if(ig) ig.addEventListener('change', npHandleInforme);
  var cq=$("np-cotizacion");   if(cq) cq.addEventListener('change', npHandleCotizacion);
});

