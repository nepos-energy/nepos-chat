      "<div style='font-size:10px;color:rgba(255,255,255,.7)'>"+nota+"</div></div>";
    return h;
  }

  $("fac-actual").innerHTML=facC("❌ FACTURA ACTUAL","var(--rj)",
    [["Cargo energía ("+Math.round(cm).toLocaleString()+" kWh)",fUSD2(fE)],
     ["Cargo dem. ("+dem.DF.toFixed(1)+"kW × $"+dem.tarDem.toFixed(4)+" — sin SGDA)",fUSD2(fD)],
     ["SAPG (cargo fijo base potencia contratada)",fS>0?fUSD2(fS):"por confirmar"],
     ["Comercialización",fUSD2(fC)],
     ["Contribución Bomberos",fB>0?fUSD2(fB):"por confirmar"]],
    "TOTAL FACTURA",totalActual,p.distComp+" · ARCONEL-006/25 · tarifa vigente");

  $("fac-sgda").innerHTML=facC("✅ CON SOLAR + SGDA","var(--vd)",
    [["Energía facturable SGDA ("+Math.round(factMes).toLocaleString()+" kWh)",fUSD2(fESGDA)],
     ["Cargo dem. 60% DMmax ("+demSGDA.DF60.toFixed(1)+"kW × $"+demSGDA.tarDem.toFixed(4)+")",fUSD2(fDsgda)],
     ["SAPG (fijo — no reducible con solar)",fS>0?fUSD2(fS):"por confirmar"],
     ["Comercialización",fUSD2(fC)],
     ["Contribución Bomberos",fB>0?fUSD2(fB):"por confirmar"]],
    "TOTAL CON SGDA",totalSGDA,"ARCONEL-005/24 + ARCONEL-001/20 · demand=60% DMmax12");

