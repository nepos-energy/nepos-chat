// DEMANDA FACTURABLE — ARCONEL-001/20 + SGDA-005/24
// Con SGDA: Demanda facturable = 60% de la demanda máxima 
//           de los últimos 12 meses (ARCONEL-001/20 Art.3)
// Sin SGDA: Demanda facturable = max(DM_mes, 60% DMmax12)
// ────────────────────────────────────────────────────────
function calcDemanda(p, conSGDA){
  var Tv = T[p.tipo];
  var DM      = p.demKW;
  var DMmax12 = p.demMax12 || DM;
  // ARCONEL-001/20: el 60% se aplica sobre la demanda máxima de los 12 meses previos
  var DF60    = 0.60 * DMmax12;
  // SIN SGDA: se factura max(demanda mes, piso 60%)
  // CON SGDA: la demanda facturable ES el 60% (el SGDA compensa la energía,
  //           y la distribuidora factura el piso de 60% de la máx. 12 meses)
  var DF;
  if(conSGDA){
    // Con sistema SGDA activo: demanda facturable = 60% DMmax12 (piso irredukible regulatorio)
    DF = DF60;
  } else {
    // Sin SGDA: factura lo que registre el medidor, mínimo el 60% del máx. 12 meses
    DF = Math.max(DM, DF60);
  }
  var tarDem  = p.tarDemReal || Tv.demanda;
  var FGDI    = p.tarDemReal ? (p.tarDemReal / Tv.demanda) : 1.0;
  return {
    DM:DM, DMmax12:DMmax12, DF60:DF60, DF:DF,
    tarDem:tarDem, tarDemPliego:Tv.demanda, FGDI:FGDI,
    cargoDem:DF*tarDem,
    cargoDemSGDA: DF60 * tarDem  // siempre el piso para referencia
  };
}

// ────────────────────────────────────────────────────────
// NEWTON-RAPHSON TIR (robusto, 400 iteraciones)
// ────────────────────────────────────────────────────────
function calcTIR(fl, guess){
  if(!fl||fl.length<2) return 0;
  var r = (guess!==undefined)?guess:0.20;
  // Guard: check if positive cashflows exist
  var pos = fl.slice(1).some(function(v){return v>0;});
  if(!pos) return -0.999;
  for(var i=0;i<400;i++){
    var f=0,df=0;
    fl.forEach(function(v,j){
      var dj=Math.pow(1+r,j);
      f  += v/dj;
      df -= j*v/((1+r)*dj);
    });
    if(Math.abs(df)<1e-12) break;
    var delta=f/df;
    r-=delta;
    // Clamp to prevent divergence
    if(r<-0.999) r=-0.999;
    if(r>100) r=100;
    if(Math.abs(delta)<1e-10) break;
  }
  return r;
}

// VPN
function calcVPN(fl, tasa){
  return fl.reduce(function(s,v,j){return s+v/Math.pow(1+tasa,j);},0);
}

// LCOE — Levelized Cost of Energy
function calcLCOE(capex, omBase, dg, kwp, yr){
  var wc  = gv('wc')/100;
  var inf = gv('inf')/100;
  var seg = gv('seg')/100;
  var totalCost = capex;
  var totalGen  = 0;
  for(var y=1;y<=yr;y++){
    var omY  = omBase*(1+inf)**(y-1);
    var segY = capex*seg*(1+inf)**(y-1);
    totalCost += (omY+segY)/Math.pow(1+wc,y);
    var genY = genSolarAnio(kwp, dg, y-1);
    totalGen += genY/Math.pow(1+wc,y);
  }
  return totalGen>0 ? totalCost/totalGen : 0;
}

// ════════════════════════════════════════════════════════
// MOTOR PRINCIPAL — FLUJOS FINANCIEROS NEPOS
// ════════════════════════════════════════════════════════
function buildFlujosNepos(){
  var p    = PROY[curP];
  var yr   = gv('yr');
  var tn   = gvS('tn', p.def.tn||0.10);
  var en   = gv('en')/100;
  var dg   = gv('dg')/100;
  var om   = gv('om');
  var inf  = gv('inf')/100;
  var seg  = gv('seg')/100;
  var cinv = gv('cinv')/100;
  var yinv = gv('yrinv');
  var wc   = gv('wc')/100;
  var capex= p.capex;
  var kwp  = p.kwp;

  // Deuda (si activa)
  var finOn = $('chk-fin') && $('chk-fin').checked;
  var dp    = gvS('dp',70)/100;
  var tea   = gvS('td',9.6)/100;
  var pd    = gvS('pd',10);
  var deuda = finOn ? capex*dp : 0;
  var equity= capex - deuda;

  // Cuota francesa mensual → anual
  var tem  = Math.pow(1+tea,1/12)-1;
  var cuotaAnio = (finOn && tem>0) ? deuda*tem/(1-Math.pow(1+tem,-pd*12))*12 : 0;

  // Flujos: año 0 = -equity (si deuda) o -capex (si equity puro)
  var fl0 = finOn ? -equity : -capex;
  var flujos  = [fl0];
  var fEq     = [fl0];   // flujos equity (post servicio deuda)
  var rows    = [];
  var ebitda_arr=[], ingr_arr=[], opex_arr=[], fcl_arr=[];
  var cumEq   = fl0;
  var pb      = 0;

  for(var y=1; y<=yr; y++){
    // ── GENERACIÓN con degradación
    var genY = genSolarAnio(kwp, dg, y-1);

    // ── INGRESO NEPOS: generación × tarifa servicio Nepos escalada
    // La tarifa Nepos es el precio del kWh del SERVICIO que Nepos cobra al cliente
    // Se escala en 'en'% anual (contractual)
    var ingrY = genY * tn * Math.pow(1+en, y-1);

    // ── OPEX NEPOS
    var omY   = om   * Math.pow(1+inf, y-1);
    var segY  = capex * seg * Math.pow(1+inf, y-1);
    var invY  = (y===yinv) ? capex*cinv : 0;
    var opexY = omY + segY + invY;

    // ── EBITDA
    var ebitdaY = ingrY - opexY;

    // ── SERVICIO DEUDA (cuota francesa, constante en $ nominales)
    var servY = (finOn && y<=pd) ? cuotaAnio : 0;

    // ── FLUJO DE CAJA LIBRE (post-deuda)
    var fclY  = ebitdaY - servY;

    // Flujos para TIR proyecto (sin deuda) y TIR equity (con deuda)
    flujos.push(ebitdaY);   // proyecto unlevered
    fEq.push(fclY);         // equity levered

    cumEq += (finOn ? fclY : ebitdaY);
    if(cumEq>=0 && pb===0) pb=y;

    var dscr = (servY>0) ? ebitdaY/servY : (ebitdaY>0?999:0);
    ebitda_arr.push(ebitdaY);
    ingr_arr.push(ingrY);
    opex_arr.push(opexY);
    fcl_arr.push(fclY);
    rows.push({y:y,gen:genY,ingr:ingrY,opex:opexY,serv:servY,ebitda:ebitdaY,fcl:fclY,dscr:dscr,cum:cumEq});
  }

  // ── VALOR RESIDUAL (20% CAPEX) añadido al ÚLTIMO flujo del año N
  var vRes = capex * 0.20;
  var flProyRes = flujos.slice();    // copia
  flProyRes[yr] += vRes;             // flujos[yr] = flujo año N (índice yr en array 1-indexed)
  var flEqRes   = fEq.slice();
  flEqRes[yr]   += vRes;

  // ── TIR y VPN
  var TIR_proy = calcTIR(flProyRes, 0.15);
  var TIR_eq   = finOn ? calcTIR(flEqRes, 0.20) : TIR_proy;
  var VPN_proy = calcVPN(flProyRes, wc);
  var VPN_eq   = finOn ? calcVPN(flEqRes, wc) : VPN_proy;

  // ── RATIOS CREDITICIOS
  var vpnEBITDA = calcVPN([0].concat(ebitda_arr), wc);
  var LLCR = deuda>0 ? vpnEBITDA/deuda : 999;
  var vpnFCL = calcVPN([0].concat(fcl_arr), wc);
  var PLCR = deuda>0 ? vpnFCL/deuda : 999;
  var dscrAll = rows.map(function(r){return r.dscr;}).filter(function(v){return v<999 && v>0;});
  var dscrMin = dscrAll.length>0 ? Math.min.apply(null,dscrAll) : 999;
  var dscrMax = dscrAll.length>0 ? Math.max.apply(null,dscrAll) : 999;

  // ── LCOE
  var LCOE = calcLCOE(capex, om, dg, kwp, yr);

  // ── PAYBACK: posición en flujosConRes (no equity)
  var cumPb=-capex, pbP=0;
  for(var y2=1;y2<=yr;y2++){
    cumPb += ebitda_arr[y2-1];
    if(cumPb>=0&&pbP===0) pbP=y2;
  }

  return {
    rows:rows, flujos:flProyRes, flEqRes:flEqRes,
    TIR:TIR_proy, TIReq:TIR_eq,
    VPN:VPN_proy, VPNeq:VPN_eq,
    pb:pbP, pbEq:pb,
    LLCR:LLCR, PLCR:PLCR,
    dscrMin:dscrMin, dscrMax:dscrMax,
    deuda:deuda, equity:equity, cuotaAnio:cuotaAnio,
    LCOE:LCOE, vRes:vRes,
    ebitda_arr:ebitda_arr, ingr_arr:ingr_arr, opex_arr:opex_arr, fcl_arr:fcl_arr
  };
}

// ════════════════════════════════════════════════════════
// FLUJO ESCENARIO CAPEX CLIENTE
// ════════════════════════════════════════════════════════
function buildFlujosCapex(){
  var p   = PROY[curP];
  var yr  = 20;
  var dg  = gv('dg')/100;
  var om  = gv('om');
  var er  = gv('er')/100;
  var wc  = gv('wc')/100;
  var tpv = tpvReal();
  var cm  = consumoMesTotal();

  var fl = [-p.capex];
  var cum=-p.capex, pb=0, gBruto=0;
  for(var y=1;y<=yr;y++){
    // Ahorro = consumo × tarifa distribuidora escalada × (1-dg)^(y-1) - O&M
    // El cliente se ahorra lo que pagaba a la distribuidora por la energía generada solar
    var tarY = tpv * Math.pow(1+er, y-1);
    var genY = genSolarAnio(p.kwp, dg, y-1);
    // Ahorro = min(gen, consumo_anual) × tarifa − OM
    // Si gen > consumo, el ahorro tope es consumo (no puede ahorrar más que su factura)
    var consAnio = cm * 12;
    var enAhorrY = Math.min(genY, consAnio) * tarY;
    var ahY = enAhorrY - om;
    fl.push(ahY);
    gBruto += ahY;
    cum += ahY;
    if(cum>=0&&pb===0) pb=y;
  }
  return {fl:fl, TIR:calcTIR(fl,0.20), VPN:calcVPN(fl,wc), pb:pb, gBruto:gBruto};
}

// ════════════════════════════════════════════════════════
// SGDA — ARCONEL-005/24 — BALANCE NETO MENSUAL
// ════════════════════════════════════════════════════════
function calcSGDA(){
  var p  = PROY[curP];
  var dg = gvS('dg', p.deg||0.5)/100;
  var Tv = T[p.tipo];
  var tp = tpvReal();
  var genMes = genSolarMes(p.kwp, dg, 0);
  var consM  = consumoMesTotal();
  var consMes = DIAS_M.map(function(d){return consM/12;});

  var tot = {gen:0,cons:0,auto:0,exc:0,def:0,comp:0,fact:0};
  var meses = [];

  for(var m=0;m<12;m++){
    var gen  = genMes[m];
    var cons = consMes[m];
    var auto = Math.min(gen, cons);
    var exc  = Math.max(0, gen-cons);
    var def  = Math.max(0, cons-gen);
    // Balance neto período: compensada = autoconsumo + min(excedente, déficit)
    // Según ARCONEL-005/24: excedentes se compensan en el mismo período de facturación
    var comp = auto + Math.min(exc, def);
    var fact = Math.max(0, cons-comp);

    // Crédito en USD (referencia tarifaria — usando tarifa ponderada del proyecto)
    var credUSD = Math.min(exc,def) * tp;

    tot.gen+=gen; tot.cons+=cons; tot.auto+=auto;
    tot.exc+=exc; tot.def+=def; tot.comp+=comp; tot.fact+=fact;

    meses.push({mes:MESES[m],gen:gen,cons:cons,auto:auto,exc:exc,def:def,comp:comp,fact:fact,credUSD:credUSD,irr:IRR_M[m]});
  }
  return {meses:meses, total:tot};
}

