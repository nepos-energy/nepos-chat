    "<span style='color:var(--vd)'>Ahorro "+fUSD2(ahNepos)+"/mes ("+ahPct.toFixed(1)+"%%)</span>";

  $("p5-kpis").innerHTML=
    kpi("Factura actual",fUSD2(totalActual),"planilla distribuidora completa","rj")+
    kpi("Solo con SGDA",fUSD2(totalSGDA),(ahSGDA>0?fUSD2(ahSGDA)+" menos":"")+" · dem.60% DMmax","am")+
    kpi("Con Nepos EaaS",fUSD2(totalNepos),"cuota + piso regulatorio","vd")+
    kpi("Ahorro mensual",fUSD2(ahNepos),ahPct.toFixed(1)+"% vs planilla anterior",ahNepos>0?"vd":"rj");

  function facC(tit,col,rows,totLbl,tot,nota){
