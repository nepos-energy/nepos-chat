// EXTRACCIÓN DE PDF — v4.6
// Estrategia en dos capas:
//   1) pdf.js sin Worker externo (disableWorker:true) → sin fetch/CORS
//   2) Si el texto extraído está vacío (PDF escaneado/imagen),
//      fallback a Claude Vision API para OCR real.
// Los parsers y la lógica financiera SGDA no se modifican.
// ══════════════════════════════════════════════════════════════

function npReadFileAsBase64(file, callback){
  var reader = new FileReader();
  reader.onload = function(e){
    var dataUrl = e.target.result;
    var base64 = dataUrl.substring(dataUrl.indexOf(',') + 1);
    callback(base64);
  };
  reader.onerror = function(){ callback(null); };
  reader.readAsDataURL(file);
}

// ── Extrae texto de una página con join consciente de líneas ────
// Agrupa ítems de pdf.js por coordenada Y para reconstruir
// líneas reales, crítico para planillas de luz en columnas.
function npItemsToText(items){
  if(!items || items.length === 0) return '';
  var lines = [];
  var curLine = [];
  var lastY = null;
  for(var i=0; i<items.length; i++){
    var it = items[i];
    var y = Math.round(it.transform[5]);
    if(lastY !== null && Math.abs(y - lastY) > 3){
      lines.push(curLine.join(' '));
      curLine = [];
    }
    if(it.str && it.str.trim()) curLine.push(it.str.trim());
    lastY = y;
  }
  if(curLine.length) lines.push(curLine.join(' '));
  return lines.join('\n');
}

// ── Renderiza una página a base64 JPEG (para fallback Vision) ──
function npRenderPageToBase64(page, scale, callback){
  try {
    var viewport = page.getViewport({ scale: scale || 2.0 });
    var canvas   = document.createElement('canvas');
    canvas.width  = viewport.width;
    canvas.height = viewport.height;
    var ctx = canvas.getContext('2d');
    page.render({ canvasContext: ctx, viewport: viewport }).promise.then(function(){
      callback(canvas.toDataURL('image/jpeg', 0.85).split(',')[1]);
    }).catch(function(){ callback(null); });
  } catch(e){ callback(null); }
}

// ── Claude Vision OCR para PDFs escaneados ─────────────────────
// Rasteriza hasta 3 páginas y las manda a Claude Sonnet con
// un prompt estructurado para extraer los campos de planilla.
function npOcrWithVision(pdfDoc, docType, onDone, onErr){
  var total   = Math.min(pdfDoc.numPages, 3);
  var images  = [];
  var pending = total;

  function tryBuild(){
    if(images.filter(Boolean).length === 0){ onErr("No se pudo rasterizar el PDF"); return; }
    var content = [];
    for(var i=0; i<images.length; i++){
      if(images[i]) content.push({ type:'image', source:{ type:'base64', media_type:'image/jpeg', data: images[i] } });
    }
    var promptMap = {
      'planillaBV': 'Sos un extractor de datos de planillas de electricidad ecuatorianas (Baja Tensión). Del documento adjunto extrae en JSON estricto (sin texto extra): consumo_total_kwh, consumo_dia_kwh, consumo_noche_kwh, demanda_kw, factura_total_usd, sapg_usd, comercializacion_usd, bomberos_usd, distribuidor. Usa null para campos no encontrados.',
      'planillaMV': 'Sos un extractor de planillas de electricidad Media Tensión Ecuador. Extrae en JSON estricto: kwh_media, kwh_punta, kwh_base, kwh_fds, demanda_kw, demanda_max_12_kw, factura_total_usd, sapg_usd, comercializacion_usd, bomberos_usd, fgdi, distribuidor. Usa null para campos no encontrados.',
      'informeFV':  'Extrae datos de un informe de generación solar (PVsyst u similar). JSON estricto: gen_anual_kwh, kwp, pr_pct, irr_kwh_kwp_dia. Usa null si no existe.',
      'cotizacion': 'Extrae datos de una cotización de sistema fotovoltaico. JSON estricto: capex_usd, kwp, om_anual_usd. Usa null si no existe.'
    };
    content.push({ type:'text', text: promptMap[docType] || promptMap['planillaBV'] });
    fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 512,
        messages: [{ role:'user', content: content }]
      })
    }).then(function(r){ return r.json(); }).then(function(data){
      try {
        var raw = (data.content||[]).filter(function(b){ return b.type==='text'; }).map(function(b){ return b.text; }).join('');
        raw = raw.replace(/```json|```/g,'').trim();
        var parsed = JSON.parse(raw);
        onDone(parsed);
      } catch(e){ onErr("Vision: respuesta no parseable — "+e); }
    }).catch(function(e){ onErr("Vision fetch error: "+e); });
  }

  for(var p=1; p<=total; p++){
    (function(pageNum){
      pdfDoc.getPage(pageNum).then(function(page){
        npRenderPageToBase64(page, 2.0, function(b64){
          images[pageNum-1] = b64;
          pending--;
          if(pending === 0) tryBuild();
        });
      }).catch(function(){
        images[pageNum-1] = null;
        pending--;
        if(pending === 0) tryBuild();
      });
    })(p);
  }
}

// ── Extractor principal ─────────────────────────────────────────
// Retorna texto extraído vía pdf.js (hilo principal, sin Worker).
// Si el texto está vacío o casi vacío, activa Vision OCR.
// docType: 'planillaBV' | 'planillaMV' | 'informeFV' | 'cotizacion'
// Los callbacks onDone y onErr se mantienen igual que antes.
// NUEVO: si Vision está activo, onDone recibe objeto JSON directo
//        en lugar de texto; la propiedad __visionParsed=true lo indica.
function npExtractPdfText(file, onDone, onErr, docType){
  if(!file){ onErr("No hay archivo"); return; }

  // Imágenes directas — derivar a Vision
  var isImage = file.type && file.type.indexOf('image/') === 0;
  if(isImage){
    onDone("__IMAGE__:"+file.name);
    return;
  }

  // Texto plano / CSV — leer directo
  if(file.type === 'text/plain' || file.type === 'text/csv' ||
     /\.(txt|csv)$/i.test(file.name)){
    var rt = new FileReader();
    rt.onload = function(e){ onDone(e.target.result || ""); };
    rt.onerror = function(){ onErr("Error leyendo texto plano"); };
    rt.readAsText(file);
    return;
  }

  // xlsx / xls / docx — leer como texto plano como fallback
  if(/\.(xlsx|xls|docx)$/i.test(file.name)){
    var rx = new FileReader();
    rx.onload = function(e){ onDone(e.target.result || ""); };
    rx.onerror = function(){ onErr("Formato no soportado para extracción automática"); };
    rx.readAsText(file);
    return;
  }

  // pdf.js sin Worker externo — elimina TODOS los errores de fetch/CORS
  if(typeof pdfjsLib === 'undefined'){
    onErr("pdf.js no disponible. Recargue la página.");
    return;
  }

  // workerSrc apunta al mismo CDN (v2.16) — elimina el warning "No workerSrc".
  // En file:// el browser bloquea el worker; el catch de loadWithWorker
  // lo detecta y reintenta automáticamente con disableWorker:true.
  pdfjsLib.GlobalWorkerOptions.workerSrc =
    'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.worker.min.js';

  var reader = new FileReader();
  reader.onload = function(e){
    var typedArray = new Uint8Array(e.target.result);

    function loadWithWorker(useWorker){
      var opts = { data: typedArray, isEvalSupported: false };
      if(!useWorker) opts.disableWorker = true;
      pdfjsLib.getDocument(opts).promise.then(function(pdfDoc){
        var total  = pdfDoc.numPages;
        if(total === 0){ onDone(""); return; }

        var pages  = new Array(total);
        var done   = 0;

        for(var i=1; i<=total; i++){
          (function(pageNum){
            pdfDoc.getPage(pageNum).then(function(page){
              page.getTextContent({ normalizeWhitespace: true }).then(function(tc){
                pages[pageNum-1] = npItemsToText(tc.items);
                done++;
                if(done === total){
                  var fullText = pages.join('\n');
                  var textLen  = fullText.replace(/\s/g,'').length;

                  if(textLen < 80){
                    // PDF escaneado — activar Claude Vision OCR
                    npOcrWithVision(pdfDoc, docType || 'planillaBV',
                      function(parsed){
                        parsed.__visionParsed = true;
                        onDone(parsed);
                      },
                      function(vErr){
                        onDone("__SCAN__:"+vErr);
                      }
                    );
                  } else {
                    onDone(fullText);
                  }
                }
              }).catch(function(){
                pages[pageNum-1] = '';
                done++;
                if(done === total) onDone(pages.join('\n'));
              });
            }).catch(function(){
              pages[pageNum-1] = '';
              done++;
              if(done === total) onDone(pages.join('\n'));
            });
          })(i);
        }
      }).catch(function(err){
        // Si falló con worker (típico en file://) — reintentar sin worker
        if(useWorker){
          loadWithWorker(false);
        } else {
          onErr("Error abriendo PDF: "+err);
        }
      });
    }

    // Intentar primero con worker; si falla (file://) reintenta sin él
    loadWithWorker(true);
  };
  reader.onerror = function(){ onErr("Error leyendo archivo"); };
  reader.readAsArrayBuffer(file);
}

// ── PARSERS LOCALES ──────────────────────────────────────────────
// Extrae un número de un texto dado un array de patrones regex
function npFindNum(text, patterns){
  for(var i=0;i<patterns.length;i++){
    var m = text.match(patterns[i]);
    if(m){
      // Limpiar el número: quitar puntos de miles, cambiar coma decimal por punto
      var raw = m[1] || m[0];
      raw = raw.replace(/\./g,'').replace(',','.');
      var n = parseFloat(raw);
      if(!isNaN(n) && n > 0) return n;
    }
  }
  return null;
}

function npParsePlanillaBV(text){
  var t = text.toUpperCase();
  var r = {};

  r.consumo_total_kwh = npFindNum(t, [
    /CONSUMO\s+TOTAL[^\d]*([\d.,]+)\s*KWH/,
    /ENERG[IÍ]A\s+ACTIVA\s+TOTAL[^\d]*([\d.,]+)/,
    /kWh\s+CONSUMIDOS[^\d]*([\d.,]+)/,
    /TOTAL\s+KWH[^\d]*([\d.,]+)/,
    /CONSUMO[^\d]*([\d.,]+)\s*KWH/
  ]);

  r.consumo_dia_kwh = npFindNum(t, [
    /D[IÍ]A[^\d]*([\d.,]+)\s*KWH/,
    /06[:\-]?00[^\d]*([\d.,]+)/,
    /HORARIO\s+DI[^\d]*([\d.,]+)/,
    /FRANJA\s+DI[^\d]*([\d.,]+)/
  ]);

  r.consumo_noche_kwh = npFindNum(t, [
    /NOCHE[^\d]*([\d.,]+)\s*KWH/,
    /22[:\-]?00[^\d]*([\d.,]+)/,
    /HORARIO\s+NOC[^\d]*([\d.,]+)/
  ]);

  r.demanda_kw = npFindNum(t, [
    /DEMANDA\s+FACTUR[^\d]*([\d.,]+)\s*KW/,
    /DEMANDA\s+M[AÁ]X[^\d]*([\d.,]+)/,
    /CARGO\s+DEMANDA[^\d]*([\d.,]+)\s*KW/,
    /POTENCIA[^\d]*([\d.,]+)\s*KW/
  ]);

  r.factura_total_usd = npFindNum(t, [
    /TOTAL\s+A\s+PAGAR[^\d]*([\d.,]+)/,
    /VALOR\s+TOTAL[^\d]*([\d.,]+)/,
    /TOTAL\s+FACTURA[^\d]*([\d.,]+)/,
    /IMPORTE\s+TOTAL[^\d]*([\d.,]+)/,
    /TOTAL[^\d]*([\d.,]+)\s*USD/
  ]);

  r.sapg_usd = npFindNum(t, [
    /SAPG[^\d]*([\d.,]+)/,
    /ALUMBRADO\s+P[UÚ]BLICO[^\d]*([\d.,]+)/,
    /CONTRIBUCI[OÓ]N\s+ALUMBRADO[^\d]*([\d.,]+)/
  ]);

  r.comercializacion_usd = npFindNum(t, [
    /COMERCIALIZACI[OÓ]N[^\d]*([\d.,]+)/,
    /CARGO\s+COMERCI[^\d]*([\d.,]+)/
  ]);

  r.bomberos_usd = npFindNum(t, [
    /BOMBEROS[^\d]*([\d.,]+)/,
    /CUERPO\s+BOMBEROS[^\d]*([\d.,]+)/,
    /CONTRIBUCI[OÓ]N\s+BOMB[^\d]*([\d.,]+)/
  ]);

  // Detectar distribuidora
  var distMap = {
    'EEQ':'EEQ','EMPRESA ELECTRICA QUITO':'EEQ',
    'EMELNORTE':'EMELNORTE',
    'CNEL':'CNEL EP','CENTROSUR':'CENTROSUR',
    'EEASA':'EEASA','ELEPCO':'ELEPCO','EERSA':'EERSA'
  };
  r.distribuidor = null;
  for(var k in distMap){ if(t.indexOf(k) !== -1){ r.distribuidor = distMap[k]; break; } }

  return r;
}

