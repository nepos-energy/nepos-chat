function loadProj(i){
  curP=i;
  var p=PROY[i];
  // Activar chips: chips 0-5 fijos + chips custom
  for(var j=0;j<=5;j++){var c=$("chip-"+j);if(c)c.classList.toggle("active",j===i);}
  for(var j=6;j<=15;j++){var c2=$("chip-"+j);if(c2)c2.classList.toggle("active",j===i);}
  var tn=$("top-proj");if(tn)tn.textContent=p.cliente+" · "+p.kwp+" kWp";

  function sv(id,val){var s=$("s-"+id),n=$("n-"+id);if(s)s.value=val;if(n)n.value=val;}
  sv("en",  p.def.en||1.5);
  sv("yr",  p.def.yr||15);
  sv("er",  p.def.er||3);
  sv("wc",  p.def.wc||12);
  sv("om",  p.def.om||p.om);
  sv("dg",  p.def.dg||p.deg||0.5);
  sv("mg",  20); sv("inf",2.5); sv("seg",0.5); sv("cinv",10); sv("yrinv",10);
  sv("irr", 4.6);
  sv("dp",70); sv("td",9.6); sv("pd",10);

  // Set descuento default and compute tn
  var dcDef = p.def.dc || 9;
  var dcS=$("s-dc"),dcN=$("n-dc");
  if(dcS)dcS.value=dcDef;
  if(dcN)dcN.value=dcDef;

  // Compute tarifa from descuento after franjas loaded
  setTimeout(function(){
    var tp2=tpvReal();
    var tn2=tp2*(1-dcDef/100);
    var ntn=$("n-tn");
    if(ntn) ntn.value=tn2.toFixed(5);
    updateLinkedDisplay(dcDef/100, tn2, tp2);
    buildP0();
    goTo(0);
  },50);
}

