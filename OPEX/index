function npCalcGen(){
  var kwp = parseFloat($("np-kwp").value)||0;
  var irr = parseFloat($("np-irr").value)||4.6;
  var pr  = (parseFloat($("np-pr").value)||80)/100;
  var genMes = kwp * irr * 30.4 * pr;
  var genAno = kwp * irr * 365 * pr;
  var gm=$("np-gen-mes"); if(gm) gm.value = kwp>0 ? Math.round(genMes) : "";
  var ga=$("np-gen-año"); if(ga) ga.value = kwp>0 ? Math.round(genAno) : "";
  npCalcCapexkwp();
}

function npCalcCapexkwp(){
  var kwp = parseFloat($("np-kwp").value)||0;
  var capex = parseFloat($("np-capex").value)||0;
  var om = parseFloat($("np-om").value)||0;
  var el = $("np-capex-kwp");
  var elo = $("np-om-pct");
  if(el && kwp>0 && capex>0) el.textContent = "→ $"+(capex/kwp).toFixed(0)+"/kWp instalado";
  else if(el) el.textContent="";
  if(elo && capex>0 && om>0) elo.textContent = "→ "+(om/capex*100).toFixed(2)+"% del CAPEX/año";
  else if(elo) elo.textContent="";
  // Auto-sugerir O&M si CAPEX ingresado
  if(capex>0 && om===0){
    var nomS=$("np-om"); if(nomS && !nomS.value) {nomS.placeholder="Sugerido: $"+Math.round(capex*0.005)+"/año (0.5%)";}
  }
}

