function buildP2(){
  var p   = PROY[curP];
  var yr  = gv('yr');
  var er  = gv('er')/100;
  var dg  = gv('dg')/100;
  var wc  = gv('wc')/100;
  var tn  = gvS('tn', p.def.tn||0.10);
  var en  = gv('en')/100;
  var tp  = tpvReal();
  var cm  = consumoMesTotal();

  var resN = buildFlujosNepos();
  var resC = buildFlujosCapex();
  var dem  = calcDemanda(p, false);

  // KPIs comparativos
  // VPN del ahorro del cliente (cuánto se ahorra en valor presente)
  var vpnAhCli = 0;
  for(var y=1;y<=yr;y++){
    var tarY = tp * Math.pow(1+er, y-1);
    var genY = genSolarAnio(p.kwp, dg, y-1);
    var consA= cm*12;
    var cuotaN = genY * tn * Math.pow(1+en, y-1);
    var ahCli = Math.min(genY,consA) * tarY - cuotaN;
    vpnAhCli += ahCli / Math.pow(1.10, y);
  }

  $("cmp-kpis").innerHTML=
    kpi("TIR Nepos",fPct(resN.TIR),yr+"a · unlevered","vd")+
    kpi("VPN Nepos",fUSD(resN.VPN),"WACC "+Math.round(wc*100)+"%","az")+
    kpi("Payback Nepos",resN.pb+"a","desde CAPEX total","")+
    kpi("VPN ahorro cliente",fUSD(Math.round(vpnAhCli)),yr+"a · tasa 10%","vd");

  // Acumulado 25 años — 3 escenarios
  var lbls=[]; var dRed=[],dCap=[],dNpos=[];
  var cumR=0, cumC=p.capex, cumN=0;
  for(var y2=0;y2<=25;y2++){
    lbls.push("A"+y2);
    dRed.push(Math.round(cumR));
    dCap.push(Math.round(cumC));
    dNpos.push(Math.round(cumN));
    var tY  = tp * Math.pow(1+er, Math.max(0,y2));
    var gY  = genSolarAnio(p.kwp, dg, Math.max(0,y2));
    var cA  = cm*12;
    cumR   += cA * tY;
    cumC   += gv('om');
    var cuotaN2 = Math.min(gY,cA) * tn * Math.pow(1+en, Math.max(0,y2));
    var facDist2= Math.max(0, cA-gY) * tY;
    cumN   += cuotaN2 + facDist2;
  }

  $("leg-cmp").innerHTML=
    lgd("var(--rj)","Solo distribuidora")+lgd("var(--vd)","CAPEX cliente")+lgd("var(--az)","OPEX Nepos EaaS");

  dCh("cmp");
  var eC=$("c-cmp");
  if(eC) charts["cmp"]=new Chart(eC,{type:"line",
    data:{labels:lbls,datasets:[
      {label:"Solo red",data:dRed,borderColor:"var(--rj)",fill:false,tension:0.2,pointRadius:1,borderWidth:2},
      {label:"CAPEX",data:dCap,borderColor:"var(--vd)",fill:false,tension:0.2,pointRadius:1,borderWidth:2},
      {label:"OPEX Nepos",data:dNpos,borderColor:"var(--az)",fill:false,tension:0.2,pointRadius:1,borderWidth:2}
    ]},
    options:{responsive:true,maintainAspectRatio:false,
      plugins:{legend:{labels:{font:{size:10}}}},
      scales:{y:{ticks:{callback:function(v){return"$"+Math.round(v/1000)+"k";},font:{size:10}}}}}});

  // Ahorro anual cliente
  var yAh=[]; var vAh=[];
  for(var y3=1;y3<=yr;y3++){
    yAh.push("A"+y3);
    var tY3=tp*Math.pow(1+er,y3-1);
    var gY3=genSolarAnio(p.kwp,dg,y3-1);
    var cA3=cm*12;
    var ahY3=Math.min(gY3,cA3)*tY3 - gY3*tn*Math.pow(1+en,y3-1);
    vAh.push(Math.round(ahY3));
  }
  dCh("ahorro");
  var eA=$("c-ahorro");
  if(eA) charts["ahorro"]=new Chart(eA,{type:"bar",
    data:{labels:yAh,datasets:[{label:"Ahorro cliente (USD/año)",data:vAh,backgroundColor:"rgba(22,163,74,0.6)",borderColor:"var(--vd)",borderWidth:1}]},
    options:{responsive:true,maintainAspectRatio:false,
      plugins:{legend:{labels:{font:{size:10}}}},
      scales:{y:{ticks:{callback:function(v){return"$"+Math.round(v/1000)+"k";},font:{size:10}}}}}});

  // Cards
  var cuotaNeposMes1SinIVA = genSolarAnio(p.kwp,dg,0)/12 * tn;
  var cuotaMes1ConIVA = cuotaNeposMes1SinIVA * 1.15;
  var ahMes1 = cm*tp - cuotaNeposMes1SinIVA;

  $("cmp-capex-card").innerHTML=
    "<div class='ct' style='color:var(--vd)'>🏗️ Esc. A — CAPEX cliente</div>"+
    "<div class='g4'>"+
      kpi("TIR cliente",fPct(resC.TIR),"20 años","vd")+
      kpi("VPN cliente",fUSD(resC.VPN),"WACC "+Math.round(wc*100)+"%","")+
      kpi("Payback",resC.pb+"a","recuperación","am")+
      kpi("Flujo 20 años",fUSD(resC.gBruto),"ahorro bruto","vd")+
    "</div>"+
    "<table style='width:100%;border-collapse:collapse;font-size:11.5px;margin-top:8px'>"+
      tblR("Inversión cliente",fUSD(p.capex)+"><span style='display:none")+
      "</table>"+
    "<table class='tbl' style='margin-top:6px'>"+
      "<tr><td>Inversión cliente</td><td style='color:var(--rj);font-weight:700'>"+fUSD(p.capex)+"</td></tr>"+
      "<tr><td>Ahorro año 1</td><td style='color:var(--vd);font-weight:600'>"+fUSD(Math.round(resC.fl[1]))+"</td></tr>"+
      "<tr><td>O&M Nepos/año</td><td>"+fUSD(gv('om'))+"</td></tr>"+
      "<tr><td>Beneficio Art.10 LRTI</td><td style='color:var(--az);font-size:10.5px'>100% deducción IR</td></tr>"+
    "</table>";

  $("cmp-opex-card").innerHTML=
    "<div class='ct' style='color:var(--az)'>⚡ Esc. B — OPEX EaaS Nepos</div>"+
    "<div class='g4'>"+
      kpi("TIR Nepos",fPct(resN.TIR),yr+"a","az")+
      kpi("VPN Nepos",fUSD(resN.VPN),"WACC "+Math.round(wc*100)+"%","")+
      kpi("Payback Nepos",resN.pb+"a","desde CAPEX","am")+
      kpi("LCOE",fUSD2(resN.LCOE)+"/kWh","nivelado","vd")+
    "</div>"+
    "<table class='tbl' style='margin-top:6px'>"+
      "<tr><td>Inversión cliente</td><td style='font-weight:700;color:var(--vd)'>$0</td></tr>"+
      "<tr><td>Generación mes 1</td><td>"+Math.round(genSolarAnio(p.kwp,dg,0)/12).toLocaleString()+" kWh</td></tr>"+
      "<tr><td>Cuota Nepos mes 1 (sin IVA)</td><td style='color:var(--az);font-weight:700'>"+fUSD(Math.round(cuotaNeposMes1SinIVA))+"/mes</td></tr>"+
      "<tr><td>Cuota Nepos mes 1 (con IVA 15%)</td><td style='font-weight:600'>"+fUSD(Math.round(cuotaMes1ConIVA))+"/mes</td></tr>"+
      "<tr><td>Ahorro energía mes 1</td><td style='color:var(--vd);font-weight:700'>"+fUSD(Math.round(ahMes1))+"/mes</td></tr>"+
      "<tr><td>Descuento vs tarifa red</td><td style='color:var(--vd);font-weight:700'>"+((1-tn/tp)*100).toFixed(1)+"%%</td></tr>"+
    "</table>"+
    "<div class='fn' style='margin-top:6px'>"+
      "<strong>Cuota = Generación × Tarifa Nepos.</strong> La tarifa Nepos ($"+tn.toFixed(5)+"/kWh) es "+
      ((1-tn/tp)*100).toFixed(1)+"% menor que la tarifa ponderada real de "+p.distComp+" ($"+tp.toFixed(5)+"/kWh). "+
      "IVA 15% aplica sobre la cuota de servicios (no sobre energía — EaaS no es venta de energía)."+
    "</div>";

  buildFinCard(resN);
  buildTablaFlujos(resN);
  buildPostContrato(resN, tp, er, dg);
}

