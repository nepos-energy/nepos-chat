    h+="</tbody></table><div style='background:"+col+";padding:9px 11px'>"+
      "<div style='display:flex;justify-content:space-between;align-items:center;margin-bottom:3px'>"+
        "<span style='font-size:10px;font-weight:700;color:rgba(255,255,255,.8)'>"+totLbl+"</span>"+
