function buildPostContrato(res, tp, er, dg){
  var p  = PROY[curP];
  var yr = gv('yr');
  var yrF= 25;
  var cm = consumoMesTotal();
  var total=0, rows="";

  for(var y=yr+1;y<=yrF;y++){
    var tY  = tp*Math.pow(1+er,y-1);
    var gY  = genSolarAnio(p.kwp,dg,y-1);
    var cA  = cm*12;
    var ahY = Math.min(gY,cA)*tY;
    total+=ahY;
    rows+="<tr><td style='text-align:left'>"+y+"</td>"+
      "<td>"+Math.round(gY/1000).toFixed(1)+" MWh</td>"+
      "<td>$"+tY.toFixed(4)+"/kWh</td>"+
      "<td style='color:var(--vd);font-weight:700'>"+fUSD(ahY)+"</td></tr>";
  }

  var el=$("cmp-post-card");
  if(!el)return;
  el.innerHTML="<div class='ct' style='color:var(--vd)'>🎁 Post-contrato años "+(yr+1)+"–"+yrF+" — Planta pasa a propiedad de "+p.cliente+"</div>"+
    "<div class='g3g' style='margin-bottom:11px'>"+
      kpi("Ahorro energía años "+(yr+1)+"–"+yrF,fUSD(Math.round(total)),"energía solar propia","vd")+
      kpi("Promedio/mes",fUSD(Math.round(total/((yrF-yr)*12))),"sin pagar a Nepos","vd")+
      kpi("Total 25 años",fUSD(Math.round(vpnAhorroHelper(tp,er,dg,yr)+total)),"valor completo contrato","vd")+
    "</div>"+
    "<div style='overflow-x:auto'><table class='tbl'>"+
      "<thead><tr><th style='text-align:left'>Año</th><th>Generación</th><th>Tarifa red</th><th>Ahorro</th></tr></thead>"+
      "<tbody>"+rows+"</tbody></table></div>"+
    "<div class='fn' style='margin-top:7px'>Al vencer el contrato en el año "+yr+", Nepos transfiere la planta sin costo adicional. "+
      "Degradación proyectada al "+gv('dg')+"% anual. Tarifa distribuidora escalación "+gv('er')+"% anual. "+
      "El piso regulatorio (demanda mínima 60% + SAPG + comercialización + bomberos) sigue siendo responsabilidad del cliente.</div>";
}

function vpnAhorroHelper(tp,er,dg,yr){
  var tn=gvS('tn',0.10), cm=consumoMesTotal(), en=gv('en')/100, p=PROY[curP], sum=0;
  for(var y=1;y<=yr;y++){
    var tY=tp*Math.pow(1+er,y-1);
    var gY=genSolarAnio(p.kwp,dg,y-1);
    var cA=cm*12;
    var ahY=Math.min(gY,cA)*tY - gY*tn*Math.pow(1+en,y-1);
    sum+=ahY/Math.pow(1.10,y);
  }
  return sum;
}

