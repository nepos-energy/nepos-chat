<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>NEPOS ENERGY — EaaS Platform v3.0</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --az:#185FA5;--az-dk:#0C447C;--az-lt:#EFF6FF;--az-bd:#BFDBFE;
  --vd:#16a34a;--vd-lt:#F0FDF4;--vd-bd:#BBF7D0;
  --am:#D97706;--am-lt:#FFFBEB;--am-bd:#FDE68A;
  --rj:#DC2626;--rj-lt:#FFF5F5;--rj-bd:#FECACA;
  --g1:#F9FAFB;--g2:#F3F4F6;--g3:#E5E7EB;--g4:#D1D5DB;
  --tx:#1A1A1A;--t2:#374151;--t3:#6B7280;--t4:#9CA3AF;
  --nr:#EF9F27;--mo:#7C3AED;
}
body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Helvetica,sans-serif;background:#EEF0F4;color:var(--tx);font-size:13px;line-height:1.5}
.topbar{background:#fff;border-bottom:2px solid var(--g3);padding:0 24px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:200;height:52px;box-shadow:0 2px 8px rgba(0,0,0,.07)}
.logo-mark{display:flex;align-items:center;gap:10px}
.logo-svg{width:32px;height:32px}
.logo-name{font-size:15px;font-weight:800;color:var(--az);letter-spacing:-.4px}
.topbar-right{display:flex;align-items:center;gap:8px}
.badge{background:var(--az-lt);color:var(--az);border:1px solid var(--az-bd);border-radius:20px;padding:3px 9px;font-size:10px;font-weight:600}
.wrap{max-width:1100px;margin:0 auto;padding:14px 18px}
.stepper{display:flex;background:#fff;border:1px solid var(--g3);border-radius:10px;overflow:hidden;margin-bottom:14px}
.step{flex:1;padding:9px 4px;text-align:center;font-size:11px;font-weight:600;color:var(--t4);cursor:pointer;border-right:1px solid var(--g3);transition:all .15s;white-space:nowrap}
.step:last-child{border-right:none}
.step.active{background:var(--az);color:#fff}
.step.done{background:var(--vd-lt);color:var(--vd)}
.panel{display:none}.panel.active{display:block}
.card{background:#fff;border:1px solid var(--g3);border-radius:10px;padding:15px 17px;margin-bottom:11px}
.ct{font-size:10.5px;font-weight:700;color:var(--t3);text-transform:uppercase;letter-spacing:.07em;margin-bottom:11px;padding-bottom:8px;border-bottom:1px solid var(--g2);display:flex;align-items:center;gap:6px}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:11px}
.g3g{display:grid;grid-template-columns:repeat(3,1fr);gap:9px}
.g4{display:grid;grid-template-columns:repeat(4,1fr);gap:9px}
.g5{display:grid;grid-template-columns:repeat(5,1fr);gap:9px}
.kpi{background:var(--g1);border:1px solid var(--g2);border-radius:8px;padding:10px;text-align:center}
.kpi-l{font-size:9.5px;font-weight:600;color:var(--t3);text-transform:uppercase;letter-spacing:.05em;margin-bottom:2px}
.kpi-v{font-size:21px;font-weight:800;color:var(--tx);line-height:1.1}
.kpi-s{font-size:9.5px;color:var(--t4);margin-top:2px}
.kpi.az{border-color:var(--az-bd);background:var(--az-lt)}.kpi.az .kpi-v{color:var(--az)}
.kpi.vd{border-color:var(--vd-bd);background:var(--vd-lt)}.kpi.vd .kpi-v{color:var(--vd)}
.kpi.rj{border-color:var(--rj-bd);background:var(--rj-lt)}.kpi.rj .kpi-v{color:var(--rj)}
.kpi.am{border-color:var(--am-bd);background:var(--am-lt)}.kpi.am .kpi-v{color:var(--am)}
.frow{display:flex;flex-direction:column;gap:2px;margin-bottom:9px}
.frow label{font-size:11.5px;color:var(--t2);font-weight:500}
.fctl{display:flex;align-items:center;gap:7px}
.fctl input[type=range]{flex:1;accent-color:var(--az);min-width:0}
.fctl input[type=number],.fctl input[type=text]{width:94px;padding:4px 7px;border:1px solid var(--g4);border-radius:6px;font-size:12px;text-align:right;background:#fff;color:var(--tx);transition:border .15s}
.fctl input:focus{outline:none;border-color:var(--az);box-shadow:0 0 0 2px rgba(24,95,165,.12)}
/* TARIFA HIGHLIGHTED INPUT */
.fctl input.tarifa-hl{border:2px solid var(--az);background:var(--az-lt);color:var(--az);font-weight:700;width:110px}
.unit{font-size:10.5px;color:var(--t4);min-width:44px}
.hint{font-size:10px;color:var(--t4);margin-top:1px}
.hint-az{font-size:10.5px;color:var(--az);margin-top:2px;font-weight:500}
.alert{padding:9px 13px;border-radius:8px;font-size:12px;margin-bottom:9px;line-height:1.6}
.al-info{background:var(--az-lt);color:#1d4ed8;border:1px solid var(--az-bd)}
.al-green{background:var(--vd-lt);color:#15803d;border:1px solid var(--vd-bd)}
.al-amber{background:var(--am-lt);color:#92400e;border:1px solid var(--am-bd)}
.al-red{background:var(--rj-lt);color:#991b1b;border:1px solid var(--rj-bd)}
.tbl{width:100%;border-collapse:collapse;font-size:11.5px}
.tbl th{font-size:10.5px;font-weight:600;color:var(--t3);text-align:right;padding:5px 7px;border-bottom:1px solid var(--g3);background:var(--g1)}
.tbl th:first-child{text-align:left}
.tbl td{padding:4px 7px;text-align:right;border-bottom:1px solid var(--g2);color:var(--t2)}
.tbl td:first-child{text-align:left;color:var(--t3)}
.tbl tr:last-child td{font-weight:700;background:var(--g1);color:var(--tx)}
.tbl tr:hover td{background:#f0f9ff}
.btn{padding:7px 14px;font-size:12px;font-weight:600;border:1px solid var(--g4);border-radius:7px;cursor:pointer;background:#fff;color:var(--t2);transition:all .15s}
.btn:hover{background:var(--g1)}
.btn-p{background:var(--az);color:#fff;border-color:var(--az)}.btn-p:hover{background:var(--az-dk)}
.btn-g{background:var(--vd);color:#fff;border-color:var(--vd)}.btn-g:hover{background:#15803d}
.btn-dk{background:#1a1a1a;color:#fff;border-color:#1a1a1a}.btn-dk:hover{background:#374151}
.nav{display:flex;gap:8px;align-items:center;margin-top:12px;padding-top:11px;border-top:1px solid var(--g2);flex-wrap:wrap}
.cw{position:relative;width:100%}.cw200{height:200px}.cw220{height:220px}.cw260{height:260px}
.chips{display:flex;gap:6px;flex-wrap:wrap;align-items:center;background:#fff;border:1px solid var(--g3);border-radius:10px;padding:9px 13px;margin-bottom:12px}
.chip{padding:5px 13px;font-size:11.5px;font-weight:600;border:1.5px solid var(--g4);border-radius:20px;cursor:pointer;background:#fff;color:var(--t3);transition:all .15s}
.chip:hover{border-color:var(--az);color:var(--az)}
.chip.active{background:var(--az);color:#fff;border-color:var(--az)}
.tabs{display:flex;border-bottom:2px solid var(--g3);margin-bottom:13px}
.tab{padding:8px 15px;font-size:12px;font-weight:600;color:var(--t3);cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-2px;transition:all .15s}
.tab.active{color:var(--az);border-bottom-color:var(--az)}
.tog{position:relative;display:inline-block;width:38px;height:20px;flex-shrink:0}
.tog input{opacity:0;width:0;height:0}
.tog-tr{position:absolute;cursor:pointer;inset:0;background:var(--g4);border-radius:20px;transition:.2s}
.tog-th{position:absolute;left:2px;top:2px;width:16px;height:16px;background:#fff;border-radius:50%;transition:.2s;box-shadow:0 1px 3px rgba(0,0,0,.2)}
.sep{height:1px;background:var(--g2);margin:9px 0}
.fn{font-size:10px;color:var(--t4);background:var(--g1);border-radius:7px;padding:8px 11px;line-height:1.7;margin-top:7px}
/* DISCOUNT+TARIFF LINKED BLOCK */
.disc-tarifa-box{background:linear-gradient(135deg,var(--az-lt) 0%,#fff 100%);border:2px solid var(--az-bd);border-radius:10px;padding:13px 15px;margin-bottom:10px}
.disc-tarifa-box .dt-row{display:grid;grid-template-columns:1fr auto 1fr;gap:12px;align-items:center}
.dt-arrow{text-align:center;font-size:18px;color:var(--az);font-weight:700}
.disc-field label,.tarifa-field label{font-size:11px;font-weight:700;color:var(--az);text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px;display:block}
.disc-field .fctl,.tarifa-field .fctl{gap:5px}
/* SENSITIVITY TABLES */
.sens-tbl{width:100%;border-collapse:collapse;font-size:11px}
.sens-tbl th{padding:5px 6px;background:var(--g1);font-size:10px;color:var(--t3);border:1px solid var(--g3)}
.sens-tbl td{padding:4px 6px;text-align:center;border:1px solid var(--g3)}
.sg{background:#dcfce7;color:#166534;font-weight:600}.sa{background:#fef9c3;color:#713f12}.sr{background:#fee2e2;color:#991b1b;font-weight:600}
.footnote-reg{background:#f8fafc;border-radius:8px;padding:9px 13px;font-size:10px;color:var(--t4);line-height:1.7;margin-bottom:4px}
@media(max-width:640px){.g2,.g4,.g5{grid-template-columns:1fr}.g3g{grid-template-columns:1fr 1fr}}
@media print{
  body{background:#fff;font-size:10.5px}
  .topbar{position:static}
  .stepper,.nav,.chips,.btn,.fctl input[type=range],.fctl input[type=number],.fctl input[type=text],.unit{display:none!important}
  .wrap{padding:10px 14px;max-width:100%}
  .panel{display:block!important}
  .panel:not(.active){display:none!important}
  .cw200,.cw220,.cw260{height:160px}
}
</style>
</head>
<body>

<div class="topbar">
  <div class="logo-mark">
    <svg class="logo-svg" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="2" y="2" width="36" height="36" rx="8" fill="#185FA5"/>
      <path d="M13 8 L20 4 L27 8 L27 22 C27 28 20 34 20 34 C20 34 13 28 13 22 Z" fill="white" opacity="0.9"/>
      <path d="M22 15 L18 15 L17 22 L20.5 22 L19 28 L24 20 L20.5 20 L22 15Z" fill="#185FA5"/>
    </svg>
    <div>
      <div class="logo-name">NEPOS ENERGY <span style="font-size:10px;font-weight:400;color:var(--t4)">EaaS Platform v3.0</span></div>
      <div style="font-size:9.5px;color:var(--t4);margin-top:-1px">Cotización EaaS · ARCONEL-006/25 · Pliego 2026</div>
    </div>
  </div>
  <div class="topbar-right">
    <span class="badge">ARCONEL-006/25</span>
    <span class="badge">SGDA-005/24</span>
    <span class="badge">Pliego 2026</span>
    <span style="font-size:10px;color:var(--t4)" id="top-proj">—</span>
  </div>
</div>

<div class="wrap">

<!-- CHIPS -->
<div class="chips">
  <span style="font-size:11.5px;color:var(--t3);font-weight:600;margin-right:3px">Proyecto:</span>
  <button class="chip active" id="chip-0" onclick="loadProj(0)">COMUMAP · 320 kWp</button>
  <button class="chip" id="chip-1" onclick="loadProj(1)">Bal.Fortaleza · 214 kWp</button>
  <button class="chip" id="chip-2" onclick="loadProj(2)">La Verde · 22.7 kWp</button>
  <button class="chip" id="chip-3" onclick="loadProj(3)">Rosas del Corazón · 138 kWp</button>
  <button class="chip" id="chip-4" onclick="loadProj(4)">Rosas 2 · 120 kWp</button>
  <button class="chip" id="chip-5" onclick="loadProj(5)">GARDAEXPORT · 1.120 kWp</button>
  <button class="chip" style="border-style:dashed;color:var(--az)" id="chip-new-btn" onclick="openNewProj()">+ Nuevo proyecto</button>
</div>

<!-- STEPPER -->
<div class="stepper">
  <div class="step active" id="step-0" onclick="goTo(0)">1 · Tarifas</div>
  <div class="step" id="step-1" onclick="goTo(1)">2 · Parámetros EaaS</div>
  <div class="step" id="step-2" onclick="goTo(2)">3 · CAPEX vs OPEX</div>
  <div class="step" id="step-3" onclick="goTo(3)">4 · Dashboards</div>
  <div class="step" id="step-4" onclick="goTo(4)">5 · Sensibilidades</div>
  <div class="step" id="step-5" onclick="goTo(5)">6 · Facturación</div>
</div>

<!-- ═══════════════════ PASO 0 — TARIFAS ═══════════════════ -->
<div class="panel active" id="panel-0">
  <div class="alert al-info" id="p0-alert"></div>
  <div class="g2">
    <div>
      <div class="card">
        <div class="ct">📋 Pliego Tarifario ARCONEL-006/25 vigente 2025-2026</div>
        <div id="p0-pliego"></div>
      </div>
      <div class="card">
        <div class="ct">⚡ Consumo real por franja horaria</div>
        <div id="p0-franjas"></div>
        <div class="sep"></div>
        <div id="p0-resumen"></div>
      </div>
    </div>
    <div>
      <div class="card">
        <div class="ct">🥧 Distribución del consumo mensual</div>
        <div class="cw cw220"><canvas id="c-franjas"></canvas></div>
        <div class="sep"></div>
        <div class="ct">🌞 Generación solar & SGDA</div>
        <div id="p0-solar" style="font-size:11.5px;color:var(--t2);line-height:1.9"></div>
      </div>
      <div class="card">
        <div class="ct">🏗️ Datos del proyecto</div>
        <div id="p0-proyecto"></div>
      </div>
    </div>
  </div>
  <div class="nav"><button class="btn btn-p" onclick="goTo(1)">Parámetros EaaS →</button></div>
</div>

<!-- ═══════════════════ PASO 1 — PARÁMETROS EaaS ═══════════════════ -->
<div class="panel" id="panel-1">
  <div class="g2">
    <div>
      <!-- DESCUENTO + TARIFA NEPOS — BLOQUE PRINCIPAL -->
      <div class="disc-tarifa-box">
        <div style="font-size:11px;font-weight:700;color:var(--az);text-transform:uppercase;letter-spacing:.06em;margin-bottom:10px">
          💡 Precio del servicio Nepos — ajusta descuento o tarifa directamente
        </div>
        <div class="dt-row">
          <div class="disc-field">
            <label>Descuento sobre tarifa red (%)</label>
            <div class="fctl">
              <input type="range" min="0.5" max="30" step="0.5" id="s-dc" value="9" oninput="sN('dc');onDcChange()">
              <input type="number" id="n-dc" value="9" step="0.5" min="0.5" max="30" oninput="sS('dc');onDcChange()">
              <span class="unit">%</span>
            </div>
            <div class="hint-az" id="dc-info">9% de descuento sobre tarifa ponderada</div>
          </div>
          <div class="dt-arrow">⟷</div>
          <div class="tarifa-field">
            <label>Tarifa Nepos al cliente (USD/kWh)</label>
            <div class="fctl">
              <input type="number" id="n-tn" value="0.10014" step="0.00001" min="0.01" max="0.30" oninput="onTnChange()" style="width:115px;padding:5px 8px;border:2px solid var(--az);border-radius:7px;font-size:13px;font-weight:700;text-align:right;background:var(--az-lt);color:var(--az)">
              <span class="unit" style="color:var(--az);font-weight:600">$/kWh</span>
            </div>
            <div class="hint-az" id="tn-info">5 decimales · actualiza automáticamente</div>
          </div>
        </div>
        <div style="margin-top:9px;padding:8px 10px;background:rgba(24,95,165,.06);border-radius:7px;font-size:11px;color:var(--t2)">
          <strong>Tarifa ponderada red:</strong> <span id="tpv-display" style="color:var(--az);font-weight:700">—</span> | 
          <strong>Ahorro mes 1:</strong> <span id="ahorro-mes1-display" style="color:var(--vd);font-weight:700">—</span> | 
          <strong>Cuota c/IVA:</strong> <span id="cuota-iva-display" style="color:var(--rj);font-weight:700">—</span>
        </div>
      </div>

      <div class="card">
        <div class="ct">📋 Contrato EaaS</div>
        <div class="frow">
          <label>Modelo de contrato</label>
          <select id="sel-modelo" style="padding:5px 8px;border:1px solid var(--g4);border-radius:6px;font-size:12px;background:#fff;color:var(--t2)">
            <option value="cuota-fija">1. Cuota fija mensual (Solar as a Service)</option>
            <option value="shared-savings">2. Shared Savings (% del ahorro)</option>
            <option value="tarifa-variable">3. Tarifa variable indexada ($/kWh)</option>
            <option value="hibrido">4. Modelo híbrido (fijo + variable)</option>
            <option value="take-or-pay">5. Take-or-Pay (mínimo garantizado)</option>
            <option value="guaranteed-savings">6. Guaranteed Savings</option>
          </select>
        </div>
        <div class="frow">
          <label>Plazo contrato EaaS (años)</label>
          <div class="fctl"><input type="range" min="5" max="25" step="1" id="s-yr" value="15" oninput="sN('yr')"><input type="number" id="n-yr" value="15" oninput="sS('yr')"><span class="unit">años</span></div>
        </div>
        <div class="frow">
          <label>Escalación tarifa Nepos (%/año)</label>
          <div class="fctl"><input type="range" min="0" max="6" step="0.5" id="s-en" value="1.5" oninput="sN('en')"><input type="number" id="n-en" value="1.5" step="0.5" oninput="sS('en')"><span class="unit">%/año</span></div>
        </div>
        <div class="frow">
          <label>Escalación tarifa distribuidora (%/año)</label>
          <div class="fctl"><input type="range" min="0" max="10" step="0.5" id="s-er" value="3" oninput="sN('er')"><input type="number" id="n-er" value="3" step="0.5" oninput="sS('er')"><span class="unit">%/año</span></div>
        </div>
      </div>

      <div class="card">
        <div class="ct">🔧 OPEX &amp; Técnico</div>
        <div class="frow"><label>O&amp;M anual base (USD/año)</label><div class="fctl"><input type="range" min="0" max="20000" step="100" id="s-om" value="1500" oninput="sN('om')"><input type="number" id="n-om" value="1500" oninput="sS('om')"><span class="unit">USD/año</span></div></div>
        <div class="frow"><label>Seguro anual (% del CAPEX)</label><div class="fctl"><input type="range" min="0" max="1.5" step="0.1" id="s-seg" value="0.5" oninput="sN('seg')"><input type="number" id="n-seg" value="0.5" step="0.1" oninput="sS('seg')"><span class="unit">%/año</span></div></div>
        <div class="frow"><label>Reposición inversores (% CAPEX, año <span id="inv-yr-lbl">10</span>)</label><div class="fctl"><input type="range" min="5" max="20" step="1" id="s-cinv" value="10" oninput="sN('cinv')"><input type="number" id="n-cinv" value="10" oninput="sS('cinv')"><span class="unit">%</span></div></div>
        <div class="frow"><label>Año de reposición inversores</label><div class="fctl"><input type="range" min="8" max="15" step="1" id="s-yrinv" value="10" oninput="sN('yrinv');document.getElementById('inv-yr-lbl').textContent=this.value"><input type="number" id="n-yrinv" value="10" oninput="sS('yrinv')"><span class="unit">año</span></div></div>
        <div class="frow"><label>Inflación OPEX (%/año)</label><div class="fctl"><input type="range" min="0" max="8" step="0.5" id="s-inf" value="2.5" oninput="sN('inf')"><input type="number" id="n-inf" value="2.5" step="0.5" oninput="sS('inf')"><span class="unit">%/año</span></div></div>
        <div class="frow"><label>Degradación paneles (%/año)</label><div class="fctl"><input type="range" min="0" max="1.5" step="0.1" id="s-dg" value="0.5" oninput="sN('dg')"><input type="number" id="n-dg" value="0.5" step="0.1" oninput="sS('dg')"><span class="unit">%/año</span></div></div>
        <div class="frow"><label>Irradiación media (kWh/kWp/día)</label><div class="fctl"><input type="range" min="3.5" max="6.0" step="0.1" id="s-irr" value="4.6" oninput="sN('irr')"><input type="number" id="n-irr" value="4.6" step="0.1" oninput="sS('irr')"><span class="unit">kWh/kWp/d</span></div></div>
      </div>
    </div>

    <div>
      <div class="card">
        <div class="ct">💰 Finanzas Nepos</div>
        <div class="frow"><label>WACC / Tasa de descuento (%)</label><div class="fctl"><input type="range" min="5" max="25" step="0.5" id="s-wc" value="12" oninput="sN('wc')"><input type="number" id="n-wc" value="12" step="0.5" oninput="sS('wc')"><span class="unit">%</span></div></div>
        <div class="frow"><label>Margen Nepos sobre servicio (%)</label><div class="fctl"><input type="range" min="5" max="40" step="1" id="s-mg" value="20" oninput="sN('mg')"><input type="number" id="n-mg" value="20" oninput="sS('mg')"><span class="unit">%</span></div></div>
        <div class="sep"></div>
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px">
          <label class="tog"><input type="checkbox" id="chk-fin" onchange="toggleFin()"><span class="tog-tr"><span class="tog-th" id="tog-th"></span></span></label>
          <div><div style="font-size:12px;font-weight:600;color:var(--t2)">Apalancamiento bancario</div><div class="hint">Modelar proyecto con deuda</div></div>
        </div>
        <div id="fin-panel" style="display:none">
          <div style="background:var(--az-lt);border:1px solid var(--az-bd);border-radius:8px;padding:11px;margin-bottom:9px">
