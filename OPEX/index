// ── BORRAR PROYECTO CUSTOM ────────────────────────────────────
function npDeleteProj(idx){
  if(!PROY[idx] || !PROY[idx]._custom) return;
  var nom = PROY[idx].nombre;
  if(!confirm("Borrar el proyecto: "+nom+". Esta accion no se puede deshacer.")) return;
  delete PROY[idx];
  // Remove chip wrapper
  var wrap = $("chip-wrap-"+idx);
  if(wrap) wrap.parentNode.removeChild(wrap);
  // If this was the active project, go to project 0
  if(curP === idx){ loadProj(0); } else { runAll(); }
}

// ── EDITAR PROYECTO CUSTOM ───────────────────────────────────
var EDITING_PROJ_IDX = null;

function npEditProj(idx){
  if(!PROY[idx]) return;
  EDITING_PROJ_IDX = idx;
  var p = PROY[idx];
  // Open modal and pre-populate all fields
  openNewProj();
  // After openNewProj resets the form, fill it with existing data
  setTimeout(function(){
    var fn=$("np-nombre");   if(fn) fn.value = p.nombre||"";
    var fc=$("np-cliente");  if(fc) fc.value = p.cliente||"";
    var fu=$("np-ubic");     if(fu) fu.value = p.ubic||"";
    var fd=$("np-dist");
    if(fd && p.distComp){
      for(var oi=0;oi<fd.options.length;oi++){
        if(fd.options[oi].value === p.distComp){ fd.selectedIndex=oi; break; }
      }
    }
    setTipoTarifa(p.tipo||'BV');
    if(p.tipo==='BV'){
      var totalBV = p.franjas.reduce(function(a,x){return a+x.kwh;},0);
      var cb=$("np-cons-bv"); if(cb) cb.value=totalBV;
      var db=$("np-dem-bv"); if(db) db.value=p.demKW||"";
      var fb=$("np-fac-bv"); if(fb) fb.value=p.facturaMes||"";
      var dayFranja = p.franjas.filter(function(f){return f.per==='dia';})[0];
      if(dayFranja && totalBV>0){
        var pctD=Math.round(dayFranja.kwh/totalBV*100);
        var pd=$("np-pct-dia"); if(pd) pd.value=pctD;
        var pn=$("np-pct-noche"); if(pn) pn.value=(100-pctD);
      }
    } else {
      p.franjas.forEach(function(f){
        if(f.per==='media'){ var q=$("np-kwh-media"); if(q) q.value=f.kwh; }
        if(f.per==='punta'){ var q=$("np-kwh-punta"); if(q) q.value=f.kwh; }
        if(f.per==='base') { var q=$("np-kwh-base");  if(q) q.value=f.kwh; }
        if(f.per==='fds')  { var q=$("np-kwh-fds");   if(q) q.value=f.kwh; }
      });
      var dm=$("np-dem-mv");    if(dm) dm.value=p.demKW||"";
      var dmx=$("np-demmax-mv");if(dmx) dmx.value=p.demMax12||"";
      var fm=$("np-fac-mv");    if(fm) fm.value=p.facturaMes||"";
      var sp=$("np-sapg");      if(sp) sp.value=p.sapg||"";
      var co=$("np-comerc");    if(co) co.value=p.comerc||4.182;
      var bo=$("np-bomb");      if(bo) bo.value=p.bomberos||"";
      npUpdateMvTarifa();
    }
    var nk=$("np-kwp");   if(nk) nk.value=p.kwp||"";
    var nc=$("np-capex"); if(nc) nc.value=p.capex||"";
    var no=$("np-om");    if(no) no.value=p.om||"";
    var ndg=$("np-deg");  if(ndg) ndg.value=p.deg||0.5;
    npCalcGen(); npCalcCapexkwp();
    // Update modal title to indicate edit mode
    var mh = document.querySelector("#modal-np [style*='font-size:16px']");
    if(mh) mh.textContent = "Editar Proyecto — "+p.nombre;
    var mb = document.querySelector("#modal-np button[onclick='npCrear()']");
    if(mb){ mb.textContent="💾 Guardar cambios"; }
  }, 80);
}


