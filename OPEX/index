  if(dcInfo) dcInfo.textContent = (dc*100).toFixed(1)+"% descuento sobre tarifa ponderada";
  if(tnInfo) tnInfo.textContent = "Tarifa: $"+tn.toFixed(5)+"/kWh — "+((1-tn/tp)*100).toFixed(1)+"% menos que red";
  if(tpvD)   tpvD.textContent   = "$"+tp.toFixed(5)+"/kWh";

  var cm   = consumoMesTotal();
  var genM = genSolarAnio(PROY[curP].kwp, gvS('dg',PROY[curP].deg||0.5)/100, 0)/12;
