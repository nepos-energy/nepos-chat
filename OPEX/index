function genSolarMes(kwp, dg, yr0){
  var irr = gvS('irr', 4.6);
  var factor = Math.pow(1-dg, yr0);
  return IRR_M.map(function(irr_m, i){
    return kwp * irr_m * DIAS_M[i] * 0.80 * factor;
  });
}
function genSolarAnio(kwp, dg, yr0){
  var irr = gvS('irr', 4.6);
  return kwp * irr * 365 * 0.80 * Math.pow(1-dg, yr0);
}

