function npValidate(){
  var errs=[];

  // Detectar qué documentos tiene adjuntos el usuario
  var fiPlanillas  = $("np-planillas");
  var fiInforme    = $("np-informe-gen");
  var fiCotizacion = $("np-cotizacion");
  var hasPlanillas  = fiPlanillas  && fiPlanillas.files  && fiPlanillas.files.length  > 0;
  var hasInforme    = fiInforme    && fiInforme.files    && fiInforme.files.length    > 0;
  var hasCotizacion = fiCotizacion && fiCotizacion.files && fiCotizacion.files.length > 0;

  // Nombre del proyecto: siempre obligatorio
  if(!($("np-nombre").value.trim())) errs.push("• Nombre del proyecto");

  // kWp: obligatorio SOLO si no hay informe FV adjunto
  if(!hasInforme){
    if(!($("np-kwp").value) || parseFloat($("np-kwp").value)<=0)
      errs.push("• Potencia instalada (kWp) — o adjunta el informe de generación");
  }

  // CAPEX: obligatorio SOLO si no hay cotización adjunta
  if(!hasCotizacion){
    if(!($("np-capex").value) || parseFloat($("np-capex").value)<=0)
      errs.push("• CAPEX del proyecto — o adjunta la cotización Nepos");
  }

  // Consumo: obligatorio SOLO si no hay planillas adjuntas
  if(!hasPlanillas){
    var tipo = $("np-tipo-val").value;
    if(tipo==='BV'){
      if(!(parseFloat($("np-cons-bv").value)>0))
        errs.push("• Consumo total kWh/mes (BV) — o adjunta las planillas de luz");
    } else {
      var tot = (parseFloat($("np-kwh-media").value)||0)+(parseFloat($("np-kwh-punta").value)||0)
               +(parseFloat($("np-kwh-base").value)||0)+(parseFloat($("np-kwh-fds").value)||0);
      if(tot<=0)
        errs.push("• Al menos un campo de consumo kWh por franja (MV) — o adjunta las planillas de luz");
    }
  }

  return errs;
}

function npGetData(){
  var tipo = $("np-tipo-val").value;
  var kwp  = parseFloat($("np-kwp").value)||0;
  var irr  = parseFloat($("np-irr").value)||4.6;
  var pr   = (parseFloat($("np-pr").value)||80)/100;
  var capex= parseFloat($("np-capex").value)||0;
  var om   = parseFloat($("np-om").value)|| Math.round(capex*0.005);
  var deg  = parseFloat($("np-deg").value)||0.5;
  var dist = $("np-dist").value;
  var nom  = $("np-nombre").value.trim() || "Nuevo proyecto";
  var cli  = $("np-cliente").value.trim() || nom;
  var ubic = $("np-ubic").value.trim() || "Ecuador";
  var facDef= 0;
  var franjas=[], demKW=0, demMax12=0, sapg=0, comerc=4.182, bomb=28.92;

  if(tipo==='BV'){
    var consBV = parseFloat($("np-cons-bv").value)||0;
    var pctDia = (parseFloat($("np-pct-dia").value)||65)/100;
    var pctNoche = 1 - pctDia;
    var kwhDia  = consBV * pctDia;
    var kwhNoche= consBV * pctNoche;
    franjas = [
      {nom:"Energía Día 06-22h",   kwh:Math.round(kwhDia),   tarifa:0.0620,per:"dia",   col:"#185FA5"},
      {nom:"Energía Noche 22-06h", kwh:Math.round(kwhNoche), tarifa:0.0520,per:"noche", col:"#888780"}
    ];
    demKW   = parseFloat($("np-dem-bv").value)||0;
    demMax12= demKW;
    facDef  = parseFloat($("np-fac-bv").value)|| Math.round(consBV*0.0620 + demKW*2.704 + 4.182);
    comerc  = 4.182;
  } else {
    var media= parseFloat($("np-kwh-media").value)||0;
    var punta= parseFloat($("np-kwh-punta").value)||0;
    var base = parseFloat($("np-kwh-base").value)||0;
    var fds  = parseFloat($("np-kwh-fds").value)||0;
    if(media>0)franjas.push({nom:"Media L-V 08-18h (solar)",kwh:Math.round(media),tarifa:0.1178,per:"media",col:"#185FA5"});
    if(punta>0)franjas.push({nom:"Punta L-V 18-22h",        kwh:Math.round(punta),tarifa:0.1318,per:"punta",col:"#D85A30"});
    if(base>0) franjas.push({nom:"Base 22-08h+S/D",          kwh:Math.round(base), tarifa:0.1001,per:"base", col:"#888780"});
    if(fds>0)  franjas.push({nom:"FdS punta 18-22h",         kwh:Math.round(fds),  tarifa:0.1178,per:"fds",  col:"#EF9F27"});
    demKW   = parseFloat($("np-dem-mv").value)||0;
    demMax12= parseFloat($("np-demmax-mv").value)||demKW;
    sapg    = parseFloat($("np-sapg").value)||0;
    comerc  = parseFloat($("np-comerc").value)||4.182;
    bomb    = parseFloat($("np-bomb").value)||28.92;
    var totMV=(media+punta+base+fds);
    var tpvMV= totMV>0 ? (media*0.1178+punta*0.1318+base*0.1001+fds*0.1178)/totMV : 0.1178;
    facDef  = parseFloat($("np-fac-mv").value)|| Math.round(totMV*tpvMV + demKW*2.620*0.87 + sapg + comerc + bomb);
  }

  // Tarifa ponderada para default descuento
  var tpvCalc = franjas.length>0 ? franjas.reduce(function(a,x){return a+x.tarifa*x.kwh;},0)/franjas.reduce(function(a,x){return a+x.kwh;},0) : 0.062;
  var tnDef = tpvCalc * (1 - 0.09);

  return {
    nombre:nom, cliente:cli, kwp:kwp, capex:capex, om:om, deg:deg,
    facturaMes: facDef, distComp:dist, ubic:ubic, tipo:tipo,
    sapg:sapg, comerc:comerc, bomberos:bomb,
    demKW:demKW, demMax12:demMax12,
    franjas:franjas,
    def:{dc:9, en:1.5, yr:15, er:3, wc:12, om:om, dg:deg},
    notaIVA:"Proyecto nuevo. Tarifa: "+(tipo==='BV'?"BV Horaria":"MV Industrial Dem.Hor.Dif.")+" | ARCONEL-006/25.",
    notaSolar:kwp+" kWp genera ~"+Math.round(kwp*irr*30.4*pr)+" kWh/mes (PR="+Math.round(pr*100)+"%). Irradiación: "+irr+" kWh/kWp/día."
  };
}

