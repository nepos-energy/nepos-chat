function buildP4(){
  var p=PROY[curP],tn=gvS('tn',p.def.tn||0.10),wc=gv('wc')/100,capexB=p.capex,dg=gv('dg')/100;
  var tp=tpvReal(),cm=consumoMesTotal(),yr=gv('yr'),er=gv('er')/100;

  function tirS(ov){
    var om2=ov.om||gv('om'),dg2=ov.dg!=null?ov.dg:dg,tn2=ov.tn||tn,cp2=ov.cap||capexB;
    var en2=ov.en||gv('en')/100,kwp2=p.kwp;
    var fl=[-cp2];
    for(var y=1;y<=yr;y++) fl.push(genSolarAnio(kwp2,dg2,y-1)*tn2*Math.pow(1+en2,y-1)-om2);
    fl[yr]+=cp2*0.20;
    return calcTIR(fl,0.15);
  }

  // TIR vs Descuento × CAPEX
  var dcVals=[5,7,9,11,13,15];
  var cpPcts=[-20,-10,0,10,20];
  var tirM=cpPcts.map(function(cp){return dcVals.map(function(dc){
    return tirS({cap:capexB*(1+cp/100),tn:tp*(1-dc/100)});
  });});
  var tirH="<table class='sens-tbl'><thead><tr><th>CAPEX↓ Disc.→</th>";
  dcVals.forEach(function(d){tirH+="<th>"+d+"%</th>";});
  tirH+="</tr></thead><tbody>";
  cpPcts.forEach(function(cp,i){
    tirH+="<tr><td>CAPEX "+(cp>=0?"+":"")+cp+"%</td>";
    tirM[i].forEach(function(v){
      var cls=v>=0.20?"sg":v>=0.12?"sa":"sr";
      tirH+="<td class='"+cls+"'>"+(v*100).toFixed(1)+"%</td>";
    });
    tirH+="</tr>";
  });
  $("sens-tir").innerHTML=tirH+"</tbody></table>";

  // VPN vs Escalación × Degradación
  var erVals=[0,1,2,3,5,7];
  var dgVals=[0.3,0.5,0.7,1.0,1.5];
  var vpnM=erVals.map(function(erV){return dgVals.map(function(dgV){
    return tirS({er:erV/100,dg:dgV/100});
  });});
  // Actually use VPN for this table
  function vpnS(ov){
    var om2=ov.om||gv('om'),dg2=ov.dg!=null?ov.dg:dg,tn2=ov.tn||tn,cp2=ov.cap||capexB;
    var en2=ov.en||gv('en')/100,kwp2=p.kwp,er2=ov.er||er;
    var fl=[-cp2];
    for(var y=1;y<=yr;y++) fl.push(genSolarAnio(kwp2,dg2,y-1)*tn2*Math.pow(1+en2,y-1)-om2);
    fl[yr]+=cp2*0.20;
    return calcVPN(fl,wc);
  }
  var vpnMat=erVals.map(function(erV){return dgVals.map(function(dgV){return vpnS({dg:dgV/100});});});
  var vpnH="<table class='sens-tbl'><thead><tr><th>Escal.↓ Deg.→</th>";
  dgVals.forEach(function(d){vpnH+="<th>"+d+"%</th>";});
  vpnH+="</tr></thead><tbody>";
  erVals.forEach(function(erV,i){
    vpnH+="<tr><td>Escal. "+erV+"%</td>";
    vpnMat[i].forEach(function(v){
      var cls=v>0?"sg":v>-capexB*0.3?"sa":"sr";
      vpnH+="<td class='"+cls+"'>"+fUSD(Math.round(v))+"</td>";
    });
    vpnH+="</tr>";
  });
  $("sens-vpn").innerHTML=vpnH+"</tbody></table>";

  // DSCR vs TEA × % Deuda
  var teaVals=[6,8,10,12,15,18];
  var dpVals=[40,50,60,70,80];
  var dscrM=teaVals.map(function(tV){return dpVals.map(function(dpV){
    var deu=capexB*dpV/100;
    var tem2=Math.pow(1+tV/100,1/12)-1;
    var cuota2=deu*tem2/(1-Math.pow(1+tem2,-gvS('pd',10)*12))*12;
    var ebitda1=genSolarAnio(p.kwp,dg,0)*tn-gv('om');
    return cuota2>0?ebitda1/cuota2:999;
  });});
  var dscrH="<table class='sens-tbl'><thead><tr><th>TEA↓ Deuda→</th>";
  dpVals.forEach(function(d){dscrH+="<th>"+d+"%%</th>";});
  dscrH+="</tr></thead><tbody>";
  teaVals.forEach(function(tV,i){
    dscrH+="<tr><td>"+tV+"%% TEA</td>";
    dscrM[i].forEach(function(v){
      var cls=v>=1.35?"sg":v>=1.25?"sa":"sr";
      dscrH+="<td class='"+cls+"'>"+(v<900?v.toFixed(2)+"x":"N/A")+"</td>";
    });
    dscrH+="</tr>";
  });
  $("sens-dscr").innerHTML=dscrH+"</tbody></table>";

  // Ahorro cliente vs tarifa red × descuento Nepos
  var erAVals=[0,2,4,6,8];
  var dcAVals=[5,7,9,11,13,15];
  var ahM=erAVals.map(function(erAV){return dcAVals.map(function(dcAV){
    var tn2=tp*(1-dcAV/100),genA=genSolarAnio(p.kwp,dg,0);
    var tpA=tp*(1+erAV/100);
    return Math.min(genA,cm*12)*tpA - genA*tn2;
  });});
  var ahH="<table class='sens-tbl'><thead><tr><th>Escal.↓ Desc.→</th>";
  dcAVals.forEach(function(d){ahH+="<th>"+d+"%%</th>";});
  ahH+="</tr></thead><tbody>";
  erAVals.forEach(function(erAV,i){
    ahH+="<tr><td>Escal. "+erAV+"%%</td>";
    ahM[i].forEach(function(v){
      var cls=v>0?"sg":v>-1000?"sa":"sr";
      ahH+="<td class='"+cls+"'>"+fUSD(Math.round(v))+"</td>";
    });
    ahH+="</tr>";
  });
  $("sens-ahorro").innerHTML=ahH+"</tbody></table>";

  // Tornado
  var base=tirS({});
  var torVars=[
    {lbl:"Descuento +/-5pp",lo:tirS({tn:tp*0.95}),hi:tirS({tn:tp*0.85})},
    {lbl:"CAPEX ±15%",      lo:tirS({cap:capexB*1.15}),hi:tirS({cap:capexB*0.85})},
    {lbl:"Degradación ±50%",lo:tirS({dg:dg*1.5}),hi:tirS({dg:dg*0.5})},
    {lbl:"Escal.tarifa ±2pp",lo:tirS({er:Math.max(0,er-0.02)}),hi:tirS({er:er+0.02})},
    {lbl:"O&M ±30%",        lo:tirS({om:gv('om')*1.3}),hi:tirS({om:gv('om')*0.7})},
    {lbl:"Irradiación ±10%", lo:tirS({tn:tn*0.90}),hi:tirS({tn:tn*1.10})}
  ];
  dCh("tornado");
  var eT=$("c-tornado");
  if(eT) charts["tornado"]=new Chart(eT,{type:"bar",
    data:{labels:torVars.map(function(v){return v.lbl;}),
      datasets:[
        {label:"Escenario bajo",data:torVars.map(function(v){return(v.lo-base)*100;}),backgroundColor:"rgba(220,38,38,0.7)"},
        {label:"Escenario alto",data:torVars.map(function(v){return(v.hi-base)*100;}),backgroundColor:"rgba(22,163,74,0.7)"}
      ]},
    options:{responsive:true,maintainAspectRatio:false,indexAxis:"y",
      plugins:{legend:{labels:{font:{size:10}}},title:{display:true,text:"Δ TIR en pp vs base "+fPct(base),font:{size:11}}},
      scales:{x:{ticks:{callback:function(v){return v.toFixed(1)+"pp";},font:{size:10}}}}}});
}

