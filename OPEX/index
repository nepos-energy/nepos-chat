  if(ahD)   ahD.textContent   = fUSD(Math.round(ahorroMes))+"/mes en energía";
  if(cuotD) cuotD.textContent = fUSD(Math.round(cuotaIVA))+"/mes";
}

// ════════════════════════════════════════════════════════
// OPTIMIZADOR — maximiza TIR Nepos con descuento >= 8%
// ════════════════════════════════════════════════════════
function optimizarTarifa(){
  var p  = PROY[curP];
  var tp = tpvReal();
  var wc = gv('wc')/100;
  var bestDc=9, bestTIR=-1;

  for(var dc=28; dc>=5; dc-=0.5){
    var tn_t = tp*(1-dc/100);
    var ntn=$("n-tn"); if(ntn) ntn.value=tn_t.toFixed(5);
    var ndc=$("n-dc"); if(ndc) ndc.value=dc.toFixed(1);
    var sdc=$("s-dc"); if(sdc) sdc.value=dc.toFixed(1);
    var res = buildFlujosNepos();
    if(res.TIR >= wc && dc >= 8){
      bestDc=dc; bestTIR=res.TIR; break;
    }
  }
  // Apply best
  var tn_f = tp*(1-bestDc/100);
  var ntn=$("n-tn"); if(ntn) ntn.value=tn_f.toFixed(5);
  var ndc=$("n-dc"); if(ndc) ndc.value=bestDc.toFixed(1);
  var sdc=$("s-dc"); if(sdc) sdc.value=bestDc.toFixed(1);
  updateLinkedDisplay(bestDc/100, tn_f, tp);

  var hint=$("opt-hint");
  if(hint) hint.textContent="✅ Óptimo: $"+tn_f.toFixed(5)+"/kWh — "+bestDc+"% desc. — TIR="+fPct(bestTIR);
  runAll();
}

